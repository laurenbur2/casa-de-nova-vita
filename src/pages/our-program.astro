---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import CTABand from "../components/CTABand.astro";
import { withBase } from "../lib/base";

const curriculum = [
  {
    title: "A Foundation for Healing",
    body: "When you arrive, we help you establish a sense of safety and stability through grounding practices, rest, and support for your physical health. From this foundation, you can feel secure enough to begin the deeper work of healing.",
  },
  {
    title: "Self-Examination",
    body: "You are guided through honest self-reflection, examining your conscience and identifying the root causes of harmful patterns. It is the beginning of understanding the inner dynamics that have shaped your past.",
  },
  {
    title: "Spiritual Development",
    body: "We create space to explore and cultivate a personal connection with the divine and the creative forces of life. This includes spiritual practice, guided work with sacrament, and the study of wisdom traditions that encourage inner growth.",
  },
  {
    title: "Acceptance & The Will to Heal",
    body: "Here you begin to accept your past and reconnect with your innate capacity to create a new, meaningful life. It is a turning point rooted in integrity, self-compassion, and the will to heal.",
  },
  {
    title: "Inner Healing",
    body: "With licensed therapists and experienced coaches, you engage in one-on-one and group healing work. These practices offer the tools and framework for change that truly lasts.",
  },
  {
    title: "Reconciliation",
    body: "We support you in rebuilding and healing relationships with the people you love. When it helps, we facilitate guided processes to restore trust, connection, and mutual understanding.",
  },
  {
    title: "Life Planning & Preparation",
    body: "As you prepare to re-enter the world, you leave with a grounded spiritual practice and an embodied orientation to healing. You will also have a clear, personalized plan to begin your new life with purpose and clarity.",
  },
];

// Short, benefit-focused lines: how each supports recovery, integration, and the nervous system.
