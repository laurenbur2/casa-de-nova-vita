---
import Layout from "../layouts/Layout.astro";
import { withBase } from "../lib/base";

// Old Squarespace links and mistyped URLs land here. Rather than a dead end,
// point people at the handful of pages someone arriving from a stale link is
// most likely looking for.
const suggestions = [
  { label: "Our program", href: "/our-program" },
  { label: "Ibogaine aftercare", href: "/ibogaine-aftercare" },
  { label: "Our story", href: "/our-story" },
  { label: "Resources & guides", href: "/resources" },
];
---

<Layout
  title="Page not found · Casa da Nova Vida"
  description="That page has moved or no longer exists. Find your way back to Casa da Nova Vida."
  noindex
  lightHeader
>
  <section class="px-6 py-10 sm:py-16 lg:px-10 lg:py-20">
    <div
      class="relative mx-auto max-w-2xl overflow-hidden rounded-[2rem] border border-sage/40 bg-gradient-to-b from-cream to-sage/35 px-8 py-10 sm:py-16 text-center sm:px-16"
    >
      <img
        src={withBase("/images/logo/mark-navy.png")}
        alt=""
        aria-hidden="true"
        class="pointer-events-none absolute -right-10 -top-10 w-56 opacity-[0.05]"
      />
      <img
        src={withBase("/images/logo/mark-navy.png")}
        alt="Casa da Nova Vida hummingbird emblem"
        class="mx-auto mb-6 w-14 opacity-90"
      />
      <p class="eyebrow">Page not found</p>
      <h1 class="mx-auto mt-4 max-w-xl text-2xl leading-tight text-pine sm:text-4xl">
        This path has moved
      </h1>
      <p class="mx-auto mt-6 max-w-lg leading-relaxed text-cocoa">
        We recently rebuilt our website, and the page you were looking for may
        have found a new home. Here are a few places to pick the thread back up.
      </p>
      <ul class="mx-auto mt-8 flex max-w-md flex-wrap justify-center gap-2.5">
        {
          suggestions.map((s) => (
            <li>
              <a
                href={withBase(s.href)}
                class="inline-block rounded-full border border-moss/40 bg-parchment/60 px-4 py-2 text-sm text-pine transition-colors hover:border-moss hover:bg-cream"
              >
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={withBase("/")}
          class="rounded-full bg-pine px-7 py-3.5 font-medium text-linen transition-colors hover:bg-forest"
        >
          Back to home
        </a>
        <a
          href={withBase("/contact")}
          class="rounded-full border border-moss/50 px-7 py-3.5 font-medium text-pine transition-colors hover:border-moss hover:bg-cream"
        >
          Get in touch
        </a>
      </div>
    </div>
  </section>
</Layout>
