---
import Layout from "../layouts/Layout.astro";
import CTABand from "../components/CTABand.astro";
import { withBase } from "../lib/base";

const reflections = [
  {
    src: "/images/photos/photo-1759273549854-Y3.jpeg",
    alt: "Reflection: Real healing requires awakening to Spirit.",
  },
  {
    src: "/images/photos/photo-1758766706004-0E.jpeg",
    alt: "Reflection: At our core — a call from our true nature — we are seekers of remembrance, understanding, and truth.",
  },
  {
    src: "/images/photos/photo-1758766705248-H2.jpeg",
    alt: "Reflection: The foundation of lasting, holistic healing is an awareness of Spirit.",
  },
  {
    src: "/images/photos/photo-1760021153294-YZ.jpeg",
    alt: "Reflection: There is a sacred phrase often spoken in esoteric spiritual traditions — I am small.",
  },
  {
    src: "/images/photos/photo-1759251955696-L6.jpeg",
    alt: "Reflection: I am free to dictate what goes on in my own mind.",
  },
];
---

<Layout
  title="Journal · Casa da Nova Vida"
  description="Reflections on healing, Spirit, and integration from Casa da Nova Vida — short meditations shared with our community."
>
  <!-- ===================== HERO ===================== -->
  <section class="bg-pine px-6 pb-24 pt-32 text-linen lg:px-10 lg:pb-28 lg:pt-40">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow rise text-gold">Journal</p>
      <h1 class="rise rise-2 mt-5 text-4xl leading-[1.12] sm:text-5xl">
        Reflections from the path
      </h1>
      <p class="rise rise-3 mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-cream/90">
        Short meditations on healing, Spirit, and integration — shared as we walk
        this path alongside our community.
      </p>
    </div>
  </section>

  <!-- ===================== REFLECTIONS GRID ===================== -->
  <section class="px-6 py-20 lg:px-10 lg:py-24">
    <div class="mx-auto grid max-w-6xl gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        reflections.map((r) => (
          <figure class="group overflow-hidden rounded-3xl ring-1 ring-sand/70 shadow-sm transition-shadow duration-300 hover:shadow-[0_24px_60px_-28px_rgba(43,54,70,0.5)]">
            <img
              src={withBase(r.src)}
              alt={r.alt}
              class="aspect-[4/5] w-full object-cover transition-transform duration-[900ms] ease-out group-hover:scale-[1.04]"
              loading="lazy"
            />
          </figure>
        ))
      }
    </div>

    <!-- Instagram follow -->
    <div class="mx-auto mt-16 max-w-2xl text-center">
      <p class="eyebrow">Follow along</p>
      <h2 class="mt-4 text-2xl text-pine sm:text-3xl">
        New reflections on Instagram
      </h2>
      <p class="mt-4 leading-relaxed text-cocoa">
        We share these meditations as they come. Follow along for the latest.
      </p>
      <a
        href="https://www.instagram.com/novavidahoh/"
        target="_blank"
        rel="noopener"
        class="mt-7 inline-flex items-center gap-2.5 rounded-full bg-pine px-7 py-3.5 font-medium text-linen transition-colors hover:bg-forest"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" />
          <circle cx="12" cy="12" r="4" />
          <circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" />
        </svg>
        @novavidahoh
      </a>
    </div>
  </section>

  <div class="pb-20 lg:pb-28"><CTABand /></div>
</Layout>
