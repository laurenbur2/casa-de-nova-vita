---
import Layout from "../layouts/Layout.astro";
import CTABand from "../components/CTABand.astro";
import PageHero from "../components/PageHero.astro";
import { withBase } from "../lib/base";

const beliefs = [
  {
    title: "Spirit at the center",
    body: "Spirituality is the cornerstone of recovering from addiction and building a life of true, balanced well-being. Healing is holistic: the spiritual, mental, emotional, and physical selves cannot be separated, and must be tended together.",
  },
  {
    title: "Humility & harm reduction",
    body: "Humility is the doorway to transformation: the willingness to be small, teachable, and honest. We hold a harm-reduction approach that honors each person's path as unique and non-linear, meeting people without judgment while gently inviting honesty and self-awareness.",
  },
  {
    title: "Place, presence & time",
    body: "Real change is not rushed. It is cultivated, like a garden, in a setting of safety, beauty, and belonging, through the quiet power of place, presence, and time.",
  },
];
---

<Layout
  title="Our Story · Casa da Nova Vida"
  description="Why Casa da Nova Vida exists: a sanctuary born from the belief that spirituality is the cornerstone of lasting recovery and a truly new life."
>
  <!-- ===================== HERO ===================== -->
  <PageHero
    eyebrow="Our Story"
    title="A call from Spirit"
    intro="Casa da Nova Vida, House of New Life, is a recovery house in the Texas Hill Country founded by Drew Walsh, offering an alternative, holistic path of healing for those working with sacred plant medicine."
    image="/images/photos/mountain-sunrise.jpg"
    imageAlt="Golden sunrise over layered, misty mountain ranges"
  />

  <!-- ===================== FOUNDER FEATURE ===================== -->
  <section class="px-6 pt-14 sm:pt-20 lg:px-10 lg:pt-20">
    <div class="relative mx-auto max-w-5xl">
      <img
        src={withBase("/images/photos/cards/drew.jpg")}
        alt="Drew Walsh, founder of Casa da Nova Vida, at golden hour in the mountains"
        class="h-[24rem] w-full rounded-[1.75rem] object-cover object-[36%_28%] shadow-lg sm:h-[30rem] lg:h-[34rem]"
        loading="eager"
      />
      <figure
        class="relative mx-auto -mt-20 max-w-md rounded-[1.5rem] bg-pine p-6 sm:p-8 text-linen shadow-xl lg:absolute lg:bottom-8 lg:right-8 lg:mx-0 lg:mt-0 lg:p-9"
      >
        <span class="font-display text-5xl leading-none text-gold/70">&ldquo;</span>
        <blockquote class="-mt-4 font-display text-xl italic leading-relaxed sm:text-2xl">
          The single most essential attribute of my sobriety became my spiritual
          awareness and my devotion to a life of healing.
        </blockquote>
        <figcaption class="mt-5 text-xs uppercase tracking-[0.2em] text-sagelight">
          Drew Walsh · Founder
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- ===================== STORY ===================== -->
  <section class="px-6 pt-12 sm:pt-16 lg:px-10 lg:pt-16">
    <div class="mx-auto max-w-3xl">
      <div class="flex items-center gap-4">
        <span class="h-px w-12 flex-none bg-gold" aria-hidden="true"></span>
        <p class="eyebrow">How it began</p>
      </div>
      <p class="mt-8 font-display text-2xl leading-[1.5] text-cocoa sm:text-[1.7rem] sm:leading-[1.5]">
        Casa da Nova Vida began with Drew's own long journey through addiction
        and recovery. Across years of using and healing, one truth kept
        surfacing: <span class="text-pine">real healing requires awakening to
        Spirit</span>. So he went all in, facing the wounds that had driven him,
        and discovering that everything he needed was already within, waiting to
        be remembered.
      </p>
      <p class="mt-8 leading-relaxed text-cocoa">
        Out of that conviction, Nova Vida was created as a recovery house for
        people walking an alternative path of healing through sacred plant
        medicine. Medicines like Ibogaine and Ayahuasca can catalyze deep
        breakthroughs, but the healing does not end when the ceremony does. The
        days and weeks that follow are among the most decisive of the entire
        journey, and too often, people are sent home to face them alone. We
        built a home instead: a place to land, stabilize, and weave those
        insights into a lasting new life.
      </p>
    </div>
  </section>

  <!-- ===================== WHAT WE BELIEVE ===================== -->
  <section class="relative isolate mt-20 overflow-hidden px-6 py-10 sm:py-16 lg:mt-16 lg:px-10 lg:py-20">
    <!-- A clearing in the woods under a deep pine wash, echoing the homepage band -->
    <img
      src={withBase("/images/photos/life/clearing.jpg")}
      alt=""
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 -z-20 h-full w-full object-cover object-center"
    />
    <div
      class="pointer-events-none absolute inset-0 -z-10 bg-pine/75"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-6xl">
      <div class="mx-auto max-w-2xl text-center [text-shadow:0_2px_20px_rgba(20,26,36,0.5)]">
        <p class="eyebrow text-gold">What we believe</p>
        <h2 class="mt-4 text-2xl text-linen sm:text-4xl">
          The convictions that shape this home
        </h2>
      </div>
      <div class="mt-9 sm:mt-14 grid gap-6 md:grid-cols-3">
        {
          beliefs.map((b, i) => (
            <div class="group rounded-3xl border border-sand bg-parchment/95 p-6 sm:p-8 shadow-lg backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-sage hover:shadow-xl">
              <div class="flex items-center gap-3">
                <span class="font-display text-4xl leading-none text-gold">
                  0{i + 1}
                </span>
                <span class="h-px flex-1 bg-sand transition-colors duration-300 group-hover:bg-sage" aria-hidden="true" />
              </div>
              <h3 class="mt-5 text-lg text-forest sm:text-xl">{b.title}</h3>
              <p class="mt-3 leading-relaxed text-cocoa">{b.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== THE CARE / PROPERTY ===================== -->
  <section class="px-6 py-12 sm:py-20 lg:px-10 lg:py-20">
    <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-2 lg:items-center lg:gap-16">
      <div class="overflow-hidden rounded-[1.75rem] shadow-lg">
        <img
          src={withBase("/images/photos/life/living-room.jpg")}
          alt="The great room with a lit stone fireplace where guests gather and talk"
          class="h-72 w-full object-cover sm:h-96 lg:h-full"
          loading="lazy"
        />
      </div>
      <div>
        <p class="eyebrow">The care you'll find here</p>
        <h2 class="mt-4 text-2xl text-pine sm:text-4xl">We keep it small</h2>
        <p class="mt-6 leading-relaxed text-cocoa">
          Our home is in the Texas Hill Country, just outside Austin. We only
          take a few guests at a time, so you're known here, not processed
          through a system. The days are simple: one-on-one coaching,
          meditation, bodywork, good meals, time outside, and plenty of rest.
          What matters most to us is what happens after the ceremony. We help you
          take the healing home and actually live it.
        </p>
        <a
          href={withBase("/our-location")}
          class="mt-8 inline-flex items-center gap-2 rounded-full bg-pine px-7 py-3.5 font-medium text-linen transition-colors hover:bg-forest"
        >
          View our location
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <div class="pb-14 sm:pb-20 lg:pb-20">
    <CTABand
      heading="Come see if this feels like home"
      body="The best way to know whether Casa da Nova Vida is right for you is simply to talk. Reach out. There is no pressure, only a conversation."
    />
  </div>
</Layout>
