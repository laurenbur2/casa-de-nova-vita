    cat: "integration",
  },
  {
    source: "Psychology Today",
    title: "The art of integration after a psychedelic experience",
    meta: "Article",
    body: "On turning insight into embodied, durable change once the ceremony ends.",
    href: "https://www.psychologytoday.com/us/blog/truth-medicine/202604/the-art-of-integration-after-a-psychedelic-experience",
    cat: "integration",
  },
  {
    source: "MAPS",
    title: "The six domains of psychedelic integration",
    meta: "Framework",
    body: "A framework for integrating across mind, body, spirit, relationships, and daily life.",
    href: "https://maps.org/integration/the-6-domains-of-psychedelic-integration/",
    cat: "integration",
  },
  {
    source: "Frontiers in Psychology",
    title: "Coping and support strategies for extended difficulties after psychedelics",
    meta: "Research",
    body: "A qualitative study of how people move through hard, lingering effects after a psychedelic experience.",
    href: "https://www.frontiersin.org/journals/psychology/articles/10.3389/fpsyg.2024.1369715/full",
    cat: "integration research",
  },
  {
    source: "Psychedelic Support",
    title: "What to do after you've taken psychedelics",
    meta: "Guide",
    body: "Concrete, grounding steps for the vulnerable days and weeks that follow.",
    href: "https://psychedelic.support/resources/now-that-its-over-what-to-do-after-youve-taken-psychedelics/",
    cat: "integration",
  },
  // Addiction & trauma
  {
    source: "Dr. Gabor Maté",
    title: "In the Realm of Hungry Ghosts",
    meta: "Book",
