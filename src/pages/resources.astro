---
import Layout from "../layouts/Layout.astro";
import CTABand from "../components/CTABand.astro";
import { withBase } from "../lib/base";

// ── Filter tags (wired to the library grid via data-cat below) ─────────────
const filters = [
  { slug: "all", label: "All" },
  { slug: "news", label: "In the News" },
  { slug: "blog", label: "Blog" },
  { slug: "addiction", label: "Addiction" },
  { slug: "trauma", label: "Trauma & PTSD" },
  { slug: "ibogaine", label: "Ibogaine" },
  { slug: "ayahuasca", label: "Ayahuasca" },
  { slug: "integration", label: "Integration" },
  { slug: "harm-reduction", label: "Harm Reduction" },
  { slug: "neuroplasticity", label: "Neuroplasticity" },
];

// ── Featured resource ──────────────────────────────────────────────────────
const featured = {
  label: "Featured · Casa da Nova Vida",
  title: "The importance of integration after plant medicine",
  body: "Insight alone does not create lasting change. Integration is how the breakthroughs of Ibogaine and Ayahuasca take root in the body, the nervous system, relationships, and daily life. A grounding place to begin.",
  href: "/ibogaine-aftercare",
  img: "/images/photos/cards/story-hero.jpg",
};

// ── Browse-by-topic cards ──────────────────────────────────────────────────
const topics = [
  { title: "Addiction", body: "Understanding addiction as a response to pain, not a moral failing.", img: "/images/photos/cards/welcome-path.jpg" },
  { title: "Trauma & PTSD", body: "How stored trauma shapes the nervous system, and how it heals.", img: "/images/photos/cards/gallery-sunset.jpg" },
  { title: "Depression", body: "Alternative, holistic paths toward relief and renewed meaning.", img: "/images/photos/attractions/jacobs-well.jpg" },
  { title: "Anxiety", body: "Regulation, presence, and calming a threat-shaped nervous system.", img: "/images/photos/cards/welcome-grow.jpg" },
  { title: "Grief", body: "Meeting loss with space, ritual, and gentle, honest support.", img: "/images/photos/attractions/san-marcos-river.jpg" },
];

// ── Resource library (real links + SEO placeholders) ───────────────────────
const library = [
  {
    source: "National Harm Reduction Coalition",
    title: "Principles of Harm Reduction",
    meta: "Guide",
    body: "Dignity, respect, and self-determination on the path of recovery, the principles that shape how we hold space.",
    href: "https://harmreduction.org/about-us/principles-of-harm-reduction/",
    img: "/images/photos/cards/gallery-meadow.jpg",
    cat: "harm-reduction news",
  },
  {
    source: "Dr. Gabor Maté",
    title: "In the Realm of Hungry Ghosts",
    meta: "Book",
    body: "Reframing addiction not as a moral failing, but as an understandable response to trauma and pain.",
    href: "https://drgabormate.com/",
    img: "/images/photos/cards/welcome-iboga.jpg",
    cat: "addiction blog",
  },
  {
    source: "Psychotherapy Networker",
    title: "Inside the Ayahuasca Experience",
    meta: "Article · 2018",
    body: "A close look at the ayahuasca experience and its place in emotional healing and recovery.",
    href: "https://www.psychotherapynetworker.org/article/inside-ayahuasca-experience-septemberoctober-2018/",
    img: "/images/photos/attractions/krause-springs.jpg",
    cat: "ayahuasca news",
  },
  {
    source: "Casa da Nova Vida",
    title: "Ibogaine and the interruption of addiction",
    meta: "Placeholder: add content",
    body: "How Ibogaine can quiet compulsive loops and open a window for lasting change.",
    href: "/ibogaine-aftercare",
    img: "/images/photos/attractions/enchanted-rock.jpg",
    cat: "ibogaine addiction",
  },
  {
    source: "Casa da Nova Vida",
    title: "The neuroscience of plant medicine",
    meta: "Placeholder: add content",
    body: "Neuroplasticity, the nervous system, and why the days after treatment matter most.",
    href: "/our-approach",
    img: "/images/photos/cards/gallery-porch.jpg",
    cat: "neuroplasticity",
  },
  {
    source: "Casa da Nova Vida",
    title: "Integration: turning insight into a new life",
    meta: "Placeholder: add content",
    body: "Practices that help the breakthroughs of ceremony become a lived, sustainable reality.",
    href: "/ibogaine-aftercare",
    img: "/images/photos/attractions/barton-springs.jpg",
    cat: "integration blog",
  },
  {
    source: "Casa da Nova Vida",
    title: "Trauma, the body, and the roots of addiction",
    meta: "Placeholder: add content",
    body: "Why lasting recovery begins with the wounds beneath the behavior.",
    href: "/our-approach",
    img: "/images/photos/cards/welcome-grow.jpg",
    cat: "trauma addiction",
  },
  {
    source: "Casa da Nova Vida",
    title: "Ayahuasca and emotional healing",
    meta: "Placeholder: add content",
    body: "Working with grief, fear, and suppressed emotion in a supported setting.",
    href: "/our-program",
    img: "/images/photos/attractions/san-marcos-river.jpg",
    cat: "ayahuasca trauma",
  },
  {
    source: "Casa da Nova Vida",
    title: "Building a life after Ibogaine",
    meta: "Placeholder: add content",
    body: "Structure, community, and embodiment in the vulnerable weeks that follow.",
    href: "/ibogaine-aftercare",
    img: "/images/photos/cards/welcome-path.jpg",
    cat: "ibogaine integration",
  },
