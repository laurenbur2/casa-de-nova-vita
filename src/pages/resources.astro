---

<Layout
  title="Resources · Casa da Nova Vida"
  description="A library of research, articles, and stories on integration and recovery after ibogaine, ayahuasca, and plant medicine, from Casa da Nova Vida."
>
  <!-- ===================== HERO ===================== -->
  <section class="relative isolate overflow-hidden px-6 pb-20 pt-24 text-linen lg:px-10 lg:pb-16 lg:pt-40">
    <img
      src={withBase(R + "hero.jpg")}
      alt="An open notebook and pen in warm window light"
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-bark/80 via-pine/75 to-pine/85"></div>
    <div class="mx-auto max-w-3xl text-center [text-shadow:0_2px_20px_rgba(20,26,36,0.55)]">
      <p class="eyebrow rise text-gold">Resources</p>
      <h1 class="rise rise-2 mt-5 text-4xl leading-[1.1] sm:text-5xl">Resources</h1>
      <p class="rise rise-3 mx-auto mt-5 font-display text-xl italic text-sagelight sm:text-2xl">
        Research, articles, and stories.
      </p>
      <p class="rise rise-3 mx-auto mt-6 max-w-2xl leading-relaxed text-cream/90">
        A growing library on healing and integration after ibogaine, ayahuasca,
        and other plant medicines. Curated to support you as you carry the work
        into a lasting new life, without relapse.
      </p>
    </div>
  </section>

  <!-- ===================== OUR GUIDES (on-site articles) ===================== -->
  {
    guides.length > 0 && (
      <section class="border-b border-sand px-6 pt-16 lg:px-10 lg:pt-16">
        <div class="mx-auto max-w-6xl">
          <p class="eyebrow">Our guides</p>
          <h2 class="mt-3 text-3xl text-pine sm:text-4xl">Written by Casa da Nova Vida</h2>
          <p class="mt-5 max-w-2xl leading-relaxed text-cocoa">
            In-depth guides to healing and integration after ibogaine, ayahuasca,
            and other plant medicines, written from our own experience and practice.
          </p>
          <div class="mt-10 grid gap-6 pb-16 sm:grid-cols-2 lg:grid-cols-3 lg:pb-16">
            {guides.map((g) => (
              <a
                href={withBase(`/${g.id}`)}
                class="group flex flex-col overflow-hidden rounded-2xl border border-sand bg-parchment shadow-sm transition-shadow duration-300 hover:shadow-[0_18px_50px_-24px_rgba(43,54,70,0.35)]"
              >
                <div class="overflow-hidden">
                  <img
                    src={withBase(g.data.heroImage)}
                    alt=""
                    class="h-44 w-full object-cover transition-transform duration-[900ms] ease-out group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="flex flex-1 flex-col p-6">
                  <p class="text-[0.7rem] uppercase tracking-[0.16em] text-clay">
                    Casa da Nova Vida · {g.data.eyebrow}
                  </p>
                  <h3 class="mt-2 text-lg leading-snug text-forest transition-colors group-hover:text-pine">
                    {g.data.title}
                  </h3>
                  <p class="mt-2 flex-1 text-sm leading-relaxed text-cocoa">{g.data.description}</p>
                  <span class="mt-5 inline-flex items-center gap-1.5 border-t border-sand pt-4 text-sm font-medium text-forest">
                    Read the guide
                    <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===================== LIBRARY + FILTERS ===================== -->
  <section class="px-6 py-16 lg:px-10 lg:py-16">
    <div class="mx-auto max-w-6xl">
      <p class="eyebrow">The library</p>
      <h2 class="mt-3 text-3xl text-pine sm:text-4xl">Reading &amp; research</h2>
      <p class="mt-5 max-w-2xl leading-relaxed text-cocoa">
        Our own reflections, plus a curated library of research and articles, from the science of
        recovery to the practice of integration.
      </p>

      <div class="mt-8 flex flex-wrap gap-2.5">
        {
          filters.map((f, i) => (
            <button
              type="button"
              data-filter={f.slug}
              class:list={["filter-pill rounded-full border px-4 py-2 text-sm transition-colors", i === 0 && "is-active"]}
            >
              {f.label}
            </button>
          ))
        }
      </div>

      <div id="library-grid" class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          library.map((r) => (
            <a
              href={r.href}
              target="_blank"
              rel="noopener"
              data-cat={r.cat}
              class="group flex flex-col overflow-hidden rounded-2xl border border-sand bg-parchment shadow-sm transition-shadow duration-300 hover:shadow-[0_18px_50px_-24px_rgba(43,54,70,0.35)]"
            >
              <div class="overflow-hidden">
                <img
                  src={withBase(r.img)}
                  alt=""
                  class="h-44 w-full object-cover transition-transform duration-[900ms] ease-out group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="flex flex-1 flex-col p-6">
                <p class="text-[0.7rem] uppercase tracking-[0.16em] text-clay">
                  {r.source} · {r.tag}
                </p>
                <h3 class="mt-2 text-lg leading-snug text-forest transition-colors group-hover:text-pine">
                  {r.title}
                </h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-cocoa">{r.body}</p>
                <span class="mt-5 inline-flex items-center gap-1.5 border-t border-sand pt-4 text-sm font-medium text-forest">
                  {r.read}
                  <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">↗</span>
                </span>
              </div>
            </a>
          ))
        }
      </div>
      <p id="library-empty" class="mt-10 hidden text-center text-cocoa">
        More on this topic coming soon.
      </p>
    </div>
  </section>

  <div class="pb-20 lg:pb-20"><CTABand /></div>
</Layout>

<script>
  const pills = Array.from(document.querySelectorAll<HTMLButtonElement>(".filter-pill"));
  const cards = Array.from(document.querySelectorAll<HTMLElement>("#library-grid [data-cat]"));
  const empty = document.getElementById("library-empty");

  pills.forEach((pill) =>
    pill.addEventListener("click", () => {
      const f = pill.dataset.filter || "all";
      pills.forEach((p) => p.classList.toggle("is-active", p === pill));
      let shown = 0;
      cards.forEach((c) => {
        const cats = (c.dataset.cat || "").split(" ");
        const show = f === "all" || cats.includes(f);
        c.style.display = show ? "" : "none";
        if (show) shown++;
      });
      empty?.classList.toggle("hidden", shown > 0);
    }),
  );
</script>

<style>
  .filter-pill {
    border-color: var(--color-sand);
    color: var(--color-cocoa);
    background-color: var(--color-parchment);
  }
  .filter-pill:hover {
    border-color: var(--color-moss);
    color: var(--color-pine);
  }
  .filter-pill.is-active {
    background-color: var(--color-pine);
    border-color: var(--color-pine);
    color: var(--color-linen);
  }
</style>
