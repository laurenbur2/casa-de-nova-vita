---
import Layout from "../layouts/Layout.astro";
import CTABand from "../components/CTABand.astro";
import { getCollection } from "astro:content";
import { withBase } from "../lib/base";

const R = "/images/photos/resources/";
const C = "/images/photos/cards/";

// On-site guides, newest first. These are our own pages (good for SEO and for
// keeping visitors on the site), shown above the curated external library.
const guides = (
  await getCollection("articles", ({ data }) => !data.draft && data.featured)
).sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// ── Filter tags (wired to the library grid via data-cat below) ─────────────
const filters = [
  { slug: "all", label: "All" },
  { slug: "resources", label: "Resources" },
];

// ── Resource library ───────────────────────────────────────────────────────
const library = [
