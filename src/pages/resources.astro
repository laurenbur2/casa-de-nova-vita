---
import Layout from "../layouts/Layout.astro";
import CTABand from "../components/CTABand.astro";
import { withBase } from "../lib/base";

// ── Filter tags (wired to the library grid via data-cat below) ─────────────
const filters = [
  { slug: "all", label: "All" },
  { slug: "ibogaine", label: "Ibogaine" },
  { slug: "ayahuasca", label: "Ayahuasca" },
  { slug: "integration", label: "Integration" },
  { slug: "addiction", label: "Addiction & Trauma" },
  { slug: "harm-reduction", label: "Harm Reduction" },
  { slug: "neuroplasticity", label: "Neuroplasticity" },
  { slug: "spirituality", label: "Spirituality" },
  { slug: "research", label: "Research" },
];

// ── Featured resource ──────────────────────────────────────────────────────
const featured = {
  label: "Featured · Stanford Medicine",
  title: "Ibogaine reduces PTSD and depression in veterans",
  body: "A landmark 2024 Stanford study found ibogaine led to dramatic, rapid reductions in PTSD, depression, and anxiety in veterans with traumatic brain injury, alongside gains in cognition, with no serious side effects.",
  href: "https://med.stanford.edu/news/all-news/2024/01/ibogaine-ptsd.html",
  img: "/images/photos/cards/welcome-iboga.jpg",
};

// ── Resource library ───────────────────────────────────────────────────────
const library = [
  // Ibogaine
  {
    source: "Nature Medicine",
    title: "Magnesium-ibogaine therapy in veterans with traumatic brain injuries",
    meta: "Study · 2024",
    body: "The peer-reviewed Stanford study behind the headlines, published in Nature Medicine.",
    href: "https://www.nature.com/articles/s41591-023-02705-w",
    cat: "ibogaine research",
  },
  {
    source: "MindScape Retreat",
    title: "Integration therapy after ibogaine: why the first 90 days matter",
    meta: "Article",
    body: "Why the window right after ibogaine is decisive, and how aftercare turns relief into lasting recovery.",
    href: "https://www.mindscaperetreat.com/news/integration-therapy-after-ibogaine-treatment-why-the-first-90-days-determine-long-term-recovery",
    cat: "ibogaine integration",
  },
  {
    source: "Psychable",
    title: "Ibogaine integration and aftercare for addiction",
    meta: "Guide",
    body: "A practical overview of the integration and aftercare that follows ibogaine treatment for addiction.",
    href: "https://psychable.com/addiction/ibogaine-integration-and-aftercare-for-addiction",
    cat: "ibogaine integration addiction",
  },
  {
    source: "PubMed",
    title: "Persisting effects following ibogaine detoxification",
    meta: "Research",
    body: "A mixed-method study of the lasting effects, and the integration needs, people report after ibogaine.",
    href: "https://pubmed.ncbi.nlm.nih.gov/30020025/",
    cat: "ibogaine research addiction",
  },
  // Ayahuasca
  {
    source: "Psychedelic Support",
    title: "Integrating ayahuasca experiences",
    meta: "Guide",
    body: "Common themes and grounded practices for bringing ayahuasca insights into everyday life.",
    href: "https://psychedelic.support/resources/integrating-ayahuasca-experiences/",
    cat: "ayahuasca integration",
  },
  {
    source: "Psychedelic Support",
    title: "Emotional healing with ayahuasca",
    meta: "Article",
    body: "How ayahuasca can surface and help process grief, fear, and long-held emotion.",
    href: "https://psychedelic.support/resources/emotional-healing-with-ayahuasca/",
    cat: "ayahuasca",
  },
  {
    source: "Ayahuasca Foundation",
    title: "Ayahuasca integration: counseling, support, and practices",
    meta: "Guide",
    body: "Counseling, community, and daily practices that help ayahuasca work take root.",
    href: "https://www.ayahuascafoundation.org/information/preparation-integration/ayahuasca-integration/",
    cat: "ayahuasca integration",
  },
  {
    source: "Psychotherapy Networker",
    title: "Inside the ayahuasca experience",
    meta: "Article · 2018",
    body: "A close, thoughtful look at the ayahuasca experience and its place in emotional healing.",
    href: "https://www.psychotherapynetworker.org/article/inside-ayahuasca-experience-septemberoctober-2018/",
    cat: "ayahuasca integration",
  },
  // Integration
  {
    source: "Frontiers in Psychology",
    title: "Psychedelic integration: an analysis of the concept and its practice",
    meta: "Research",
