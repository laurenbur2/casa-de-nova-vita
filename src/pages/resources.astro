    href: "https://www.tandfonline.com/doi/full/10.1080/08897077.2021.1941514",
    cat: "spirituality addiction research",
  },
  {
    source: "PMC",
    title: "Spirituality, life meaning, and quality of life in recovery",
    meta: "Research",
    body: "On how spirituality, meaning, and social support relate to well-being in long-term recovery.",
    href: "https://pmc.ncbi.nlm.nih.gov/articles/PMC1526775/",
    cat: "spirituality addiction research",
  },
  // Research centers & support
  {
    source: "Johns Hopkins",
    title: "Center for Psychedelic and Consciousness Research",
    meta: "Research center",
    body: "The largest psychedelic research center of its kind, with 150+ peer-reviewed studies.",
    href: "https://www.hopkinspsychedelic.org/",
    cat: "research integration",
  },
  {
    source: "MAPS",
    title: "Psychedelic education and support resources",
    meta: "Organization",
    body: "The Multidisciplinary Association for Psychedelic Studies' hub of research and integration resources.",
    href: "https://maps.org/take-action/resources/",
    cat: "integration research",
  },
  {
    source: "Fireside Project",
    title: "Psychedelic peer support line",
    meta: "Support",
    body: "Free, confidential peer support during and after psychedelic experiences. Call or text 62-FIRESIDE.",
    href: "https://firesideproject.org/",
    cat: "integration",
  },
];
---

<Layout
  title="Resources · Casa da Nova Vida"
  description="A library of research, articles, and stories on integration and recovery after ibogaine, ayahuasca, and plant medicine, from Casa da Nova Vida."
>
  <!-- ===================== HERO ===================== -->
  <section class="bg-pine px-6 pb-20 pt-32 text-linen lg:px-10 lg:pb-24 lg:pt-40">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow rise text-gold">Resources</p>
      <h1 class="rise rise-2 mt-5 text-4xl leading-[1.1] sm:text-5xl">Resources</h1>
      <p class="rise rise-3 mx-auto mt-5 font-display text-xl italic text-sagelight sm:text-2xl">
        Research, articles, and stories.
      </p>
      <p class="rise rise-3 mx-auto mt-6 max-w-2xl leading-relaxed text-cream/90">
        A growing library on healing and integration after ibogaine, ayahuasca,
        and other plant medicines. Curated to support you as you carry the work
        into a lasting new life, without relapse.
      </p>
    </div>
  </section>

  <!-- ===================== FEATURED ===================== -->
  <section class="px-6 pt-16 lg:px-10 lg:pt-20">
    <div class="mx-auto max-w-6xl">
      <a
        href={featured.href}
        target="_blank"
        rel="noopener"
        class="group grid overflow-hidden rounded-[1.75rem] border border-sand bg-parchment shadow-sm transition-shadow duration-300 hover:shadow-[0_24px_60px_-28px_rgba(43,54,70,0.4)] md:grid-cols-2"
      >
        <div class="overflow-hidden">
          <img
            src={withBase(featured.img)}
            alt=""
            class="h-64 w-full object-cover transition-transform duration-[900ms] ease-out group-hover:scale-105 md:h-full"
            loading="lazy"
          />
        </div>
        <div class="flex flex-col justify-center p-8 lg:p-12">
          <p class="eyebrow text-clay">{featured.label}</p>
          <h3 class="mt-4 text-2xl text-pine sm:text-3xl">{featured.title}</h3>
          <p class="mt-4 leading-relaxed text-cocoa">{featured.body}</p>
          <span class="mt-6 inline-flex items-center gap-2 font-medium text-forest">
            Read the study <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
          </span>
        </div>
      </a>
    </div>
  </section>

  <!-- ===================== LIBRARY + FILTERS ===================== -->
  <section class="px-6 py-16 lg:px-10 lg:py-24">
    <div class="mx-auto max-w-6xl">
      <p class="eyebrow">The library</p>
      <h2 class="mt-3 text-3xl text-pine sm:text-4xl">Reading &amp; research</h2>
      <p class="mt-5 max-w-2xl leading-relaxed text-cocoa">
        Filter by topic to find what meets you where you are, from the science of
        recovery to the practice of integration.
      </p>

      <div class="mt-8 flex flex-wrap gap-2.5">
        {
          filters.map((f, i) => (
            <button
              type="button"
              data-filter={f.slug}
              class:list={["filter-pill rounded-full border px-4 py-2 text-sm transition-colors", i === 0 && "is-active"]}
            >
              {f.label}
            </button>
          ))
        }
      </div>

      <div id="library-grid" class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          library.map((r) => (
            <a
              href={r.href}
              target="_blank"
              rel="noopener"
              data-cat={r.cat}
              class="group flex flex-col rounded-2xl border border-sand bg-parchment p-6 shadow-sm transition-shadow duration-300 hover:shadow-[0_18px_50px_-24px_rgba(43,54,70,0.35)]"
            >
              <p class="text-[0.7rem] uppercase tracking-[0.16em] text-clay">{r.source}</p>
              <h3 class="mt-2 text-lg leading-snug text-forest transition-colors group-hover:text-pine">
                {r.title}
              </h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-cocoa">
                <span class="text-stone">{r.meta}</span> · {r.body}
              </p>
              <span class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-forest">
                Read <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
              </span>
            </a>
          ))
        }
      </div>
      <p id="library-empty" class="mt-10 hidden text-center text-cocoa">
        More on this topic coming soon.
      </p>
    </div>
  </section>

  <div class="pb-20 lg:pb-28"><CTABand /></div>
</Layout>

<script>
  const pills = Array.from(document.querySelectorAll<HTMLButtonElement>(".filter-pill"));
  const cards = Array.from(document.querySelectorAll<HTMLElement>("#library-grid [data-cat]"));
  const empty = document.getElementById("library-empty");

  pills.forEach((pill) =>
    pill.addEventListener("click", () => {
      const f = pill.dataset.filter || "all";
      pills.forEach((p) => p.classList.toggle("is-active", p === pill));
      let shown = 0;
      cards.forEach((c) => {
        const cats = (c.dataset.cat || "").split(" ");
        const show = f === "all" || cats.includes(f);
        c.style.display = show ? "" : "none";
        if (show) shown++;
      });
      empty?.classList.toggle("hidden", shown > 0);
    }),
  );
</script>

<style>
  .filter-pill {
    border-color: var(--color-sand);
    color: var(--color-cocoa);
    background-color: var(--color-parchment);
  }
  .filter-pill:hover {
    border-color: var(--color-moss);
    color: var(--color-pine);
  }
  .filter-pill.is-active {
    background-color: var(--color-pine);
    border-color: var(--color-pine);
    color: var(--color-linen);
  }
</style>
