---

<Layout
  title="Resources · Casa da Nova Vida"
  description="A library of articles, research, and stories on healing, harm reduction, plant medicine, and integration from Casa da Nova Vida."
>
  <!-- ===================== HERO ===================== -->
  <section class="bg-pine px-6 pb-20 pt-32 text-linen lg:px-10 lg:pb-24 lg:pt-40">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow rise text-gold">Resources</p>
      <h1 class="rise rise-2 mt-5 text-4xl leading-[1.1] sm:text-5xl">Resources</h1>
      <p class="rise rise-3 mx-auto mt-5 font-display text-xl italic text-sagelight sm:text-2xl">
        Articles, guides, and stories.
      </p>
      <p class="rise rise-3 mx-auto mt-6 max-w-2xl leading-relaxed text-cream/90">
        A growing library of reading on healing, harm reduction, plant medicine,
        and integration, curated to support you wherever you are on the path.
      </p>
    </div>
  </section>

  <!-- ===================== LIBRARY + FILTERS ===================== -->
  <section class="px-6 pt-16 lg:px-10 lg:pt-24">
    <div class="mx-auto max-w-6xl">
      <p class="eyebrow">Library</p>
      <h2 class="mt-3 text-3xl text-pine sm:text-4xl">Articles, research &amp; stories</h2>
      <p class="mt-5 max-w-2xl leading-relaxed text-cocoa">
        A curated collection to help you understand the path of healing, from
        the science of recovery to first-hand stories of transformation.
      </p>

      <div class="mt-8 flex flex-wrap gap-2.5">
        {
          filters.map((f, i) => (
            <button
              type="button"
              data-filter={f.slug}
              class:list={["filter-pill rounded-full border px-4 py-2 text-sm transition-colors", i === 0 && "is-active"]}
            >
              {f.label}
            </button>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== FEATURED ===================== -->
  <section class="px-6 pt-12 lg:px-10 lg:pt-16">
    <div class="mx-auto max-w-6xl">
      <a
        href={withBase(featured.href)}
        class="group grid overflow-hidden rounded-[1.75rem] border border-sand bg-parchment shadow-sm transition-shadow duration-300 hover:shadow-[0_24px_60px_-28px_rgba(43,54,70,0.4)] md:grid-cols-2"
      >
        <div class="overflow-hidden">
          <img
            src={withBase(featured.img)}
            alt=""
            class="h-64 w-full object-cover transition-transform duration-[900ms] ease-out group-hover:scale-105 md:h-full"
            loading="lazy"
          />
        </div>
        <div class="flex flex-col justify-center p-8 lg:p-12">
          <p class="eyebrow text-clay">{featured.label}</p>
          <h3 class="mt-4 text-2xl text-pine sm:text-3xl">{featured.title}</h3>
          <p class="mt-4 leading-relaxed text-cocoa">{featured.body}</p>
          <span class="mt-6 inline-flex items-center gap-2 font-medium text-forest">
            Read article <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
          </span>
        </div>
      </a>
    </div>
  </section>

  <!-- ===================== BROWSE BY TOPIC ===================== -->
  <section class="px-6 py-16 lg:px-10 lg:py-24">
    <div class="mx-auto max-w-6xl">
      <p class="eyebrow">Browse by topic</p>
      <h2 class="mt-3 text-3xl text-pine sm:text-4xl">Where you are on the path</h2>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-5">
        {
          topics.map((t) => (
            <article class="group overflow-hidden rounded-2xl border border-sand bg-parchment transition-shadow duration-300 hover:shadow-[0_16px_40px_-22px_rgba(43,54,70,0.4)]">
              <div class="overflow-hidden">
                <img src={withBase(t.img)} alt="" class="h-32 w-full object-cover transition-transform duration-[900ms] ease-out group-hover:scale-105" loading="lazy" />
              </div>
              <div class="p-5">
                <p class="text-[0.7rem] uppercase tracking-[0.16em] text-clay">Topic</p>
                <h3 class="mt-1.5 text-lg text-forest">{t.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-cocoa">{t.body}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== RESOURCE LIBRARY GRID ===================== -->
  <section class="border-t border-sand bg-cream px-6 py-16 lg:px-10 lg:py-24">
    <div class="mx-auto max-w-6xl">
      <p class="eyebrow">The library</p>
      <h2 class="mt-3 text-3xl text-pine sm:text-4xl">Reading &amp; references</h2>

      <div id="library-grid" class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          library.map((r) => (
            <a
              href={withBase(r.href)}
              target={r.href.startsWith("http") ? "_blank" : undefined}
              rel={r.href.startsWith("http") ? "noopener" : undefined}
              data-cat={r.cat}
              class="group flex flex-col overflow-hidden rounded-2xl border border-sand bg-parchment shadow-sm transition-shadow duration-300 hover:shadow-[0_18px_50px_-24px_rgba(43,54,70,0.35)]"
            >
              <div class="overflow-hidden">
                <img src={withBase(r.img)} alt="" class="h-44 w-full object-cover transition-transform duration-[900ms] ease-out group-hover:scale-105" loading="lazy" />
              </div>
              <div class="flex flex-1 flex-col p-6">
                <p class="text-[0.7rem] uppercase tracking-[0.16em] text-clay">{r.source}</p>
                <h3 class="mt-2 text-xl leading-snug text-forest">{r.title}</h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-cocoa">
                  <span class="text-stone">{r.meta}</span>. {r.body}
                </p>
                <span class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-forest">
                  Read <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
                </span>
              </div>
            </a>
          ))
        }
      </div>
      <p id="library-empty" class="mt-10 hidden text-center text-cocoa">
        More on this topic coming soon.
      </p>
    </div>
  </section>

  <div class="py-20 lg:py-28"><CTABand /></div>
</Layout>

<script>
  const pills = Array.from(document.querySelectorAll<HTMLButtonElement>(".filter-pill"));
  const cards = Array.from(document.querySelectorAll<HTMLElement>("#library-grid [data-cat]"));
  const empty = document.getElementById("library-empty");

  pills.forEach((pill) =>
    pill.addEventListener("click", () => {
      const f = pill.dataset.filter || "all";
      pills.forEach((p) => p.classList.toggle("is-active", p === pill));
      let shown = 0;
      cards.forEach((c) => {
        const cats = (c.dataset.cat || "").split(" ");
        const show = f === "all" || cats.includes(f);
        c.style.display = show ? "" : "none";
        if (show) shown++;
      });
      empty?.classList.toggle("hidden", shown > 0);
    }),
  );
</script>

<style>
  .filter-pill {
    border-color: var(--color-sand);
    color: var(--color-cocoa);
    background-color: var(--color-parchment);
  }
  .filter-pill:hover {
    border-color: var(--color-moss);
    color: var(--color-pine);
  }
  .filter-pill.is-active {
    background-color: var(--color-pine);
    border-color: var(--color-pine);
    color: var(--color-linen);
  }
</style>
