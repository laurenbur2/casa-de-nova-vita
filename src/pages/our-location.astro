---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import CTABand from "../components/CTABand.astro";
import { withBase } from "../lib/base";

const nearby = [
  {
    name: "Barton Springs",
    img: "/images/photos/attractions/barton-springs.jpg",
    alt: "The clear, spring-fed water of Barton Springs in Austin",
    body: "The jewel of Austin: Barton Springs. This local watering hole is spring-fed and maintains a consistent 68 degrees year round.",
  },
  {
    name: "Zilker Park",
    img: "/images/photos/attractions/zilker-park.jpg",
    alt: "The green lawn of Zilker Park with the Austin skyline beyond",
    body: "A 350-acre park in the heart of Austin, home to Barton Springs Pool, botanical gardens, and wide green lawns along the river.",
  },
  {
    name: "Enchanted Rock",
    img: "/images/photos/attractions/enchanted-rock.jpg",
    alt: "The pink granite dome of Enchanted Rock",
    body: "Enchanted Rock State Natural Area, part of the Texas state park system, spans 1,644 acres around a massive dome of pink granite.",
  },
  {
    name: "San Marcos River",
    img: "/images/photos/attractions/san-marcos-river.jpg",
    alt: "The clear, tree-lined San Marcos River",
    body: "The San Marcos River rises from the San Marcos Springs, the location of the Meadows Center for Water and the Environment, in San Marcos, Texas.",
  },
  {
    name: "Jacob's Well",
    img: "/images/photos/attractions/jacobs-well.jpg",
    alt: "The deep blue spring of Jacob's Well",
    body: "Jacob's Well is a perennial spring in the Texas Hill Country flowing from the bed of Cypress Creek, located northwest of Wimberley, Texas.",
  },
  {
    name: "Krause Springs",
    img: "/images/photos/attractions/krause-springs.jpg",
    alt: "The lush green swimming hole at Krause Springs",
    body: "The 115-acre property has 32 springs, several feeding the man-made and natural pools that flow into Lake Travis.",
  },
];

const gallery = [
  {
    src: "/images/photos/life/church-gathering.jpg",
    alt: "Guests and staff gathered around the table for worship, with a cross, candle, and guitar",
  },
  {
    src: "/images/photos/life/living-room.jpg",
    alt: "The great room with a lit stone fireplace where guests gather and talk",
  },
  {
    src: "/images/photos/life/kitchen.jpg",
    alt: "The open kitchen where guests share meals and learn to cook",
  },
  {
    src: "/images/photos/life/clearing.jpg",
    alt: "An energetic clearing under the oaks in the Hill Country",
  },
];
---

<Layout
  title="Our Location · Casa da Nova Vida"
  description="A serene recovery house in the Texas Hill Country near Austin: spring-fed waters, hiking trails, and rivers that play a key role in the experience we offer."
>
  <PageHero
    eyebrow="Texas Hill Country · Austin, TX"
    title="Our Location"
    image="/images/photos/cards/house.jpg"
    imageAlt="The stone sanctuary house framed by hill country oaks"
  />

  <!-- ===================== INTRO ===================== -->
  <section class="px-6 py-16 lg:px-10 lg:py-24">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-lg leading-relaxed text-cocoa sm:text-xl sm:leading-relaxed">
        Our recovery house is located in the Texas Hill Country near Austin,
        Texas, known for its clear, spring-fed waters and scenic surroundings.
        The broader Central Texas area, with its hiking trails, natural swimming
        holes, and rivers, plays a key role in the experience we offer. This
        serene environment supports our guests on their journey toward
        integration and healing, providing a peaceful setting that encourages
        reflection and rejuvenation.
      </p>
    </div>
  </section>

  <!-- ===================== GALLERY ===================== -->
  <section class="px-6 pb-20 lg:px-10 lg:pb-28">
    <div class="mx-auto mb-10 max-w-3xl text-center">
      <p class="eyebrow">A glimpse of life here</p>
      <h2 class="mt-3 text-3xl text-pine sm:text-4xl">Inside the house</h2>
    </div>
    <div class="mx-auto grid max-w-5xl grid-cols-1 gap-5 sm:grid-cols-2 sm:gap-6">
      {
        gallery.map((g) => (
          <img
            src={withBase(g.src)}
            alt={g.alt}
            class="h-64 w-full rounded-2xl object-cover shadow-sm sm:h-72"
            loading="lazy"
          />
        ))
      }
    </div>
  </section>

  <!-- ===================== OTHER LOCAL ATTRACTIONS (carousel) ===================== -->
  <section class="overflow-hidden bg-cream py-20 lg:py-28">
    <div class="mx-auto max-w-6xl px-6 lg:px-10">
      <div class="flex items-end justify-between gap-4">
        <div>
          <p class="eyebrow">Explore nearby</p>
          <h2 class="mt-3 text-3xl text-pine sm:text-4xl">Other local attractions</h2>
        </div>
        <div class="hidden shrink-0 gap-2 sm:flex">
          <button
            type="button"
            data-scroll="prev"
            aria-label="Scroll left"
            class="carousel-btn flex h-11 w-11 items-center justify-center rounded-full border border-moss/40 text-pine transition-colors hover:border-moss hover:bg-linen"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6" /></svg>
          </button>
          <button
            type="button"
            data-scroll="next"
            aria-label="Scroll right"
            class="carousel-btn flex h-11 w-11 items-center justify-center rounded-full border border-moss/40 text-pine transition-colors hover:border-moss hover:bg-linen"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6" /></svg>
          </button>
        </div>
      </div>
    </div>

    <div
      id="attractions-track"
      class="no-scrollbar mt-10 flex snap-x snap-mandatory gap-6 overflow-x-auto scroll-smooth px-6 pb-4 lg:px-10"
    >
      {
        nearby.map((n) => (
          <article class="w-[19rem] shrink-0 snap-start sm:w-[21rem]">
            <div class="overflow-hidden rounded-3xl shadow-sm ring-1 ring-sand/70">
              <img
                src={withBase(n.img)}
                alt={n.alt}
                class="h-60 w-full object-cover"
                loading="lazy"
              />
            </div>
            <h3 class="mt-4 text-xl text-forest">{n.name}</h3>
            <p class="mt-2 text-sm leading-relaxed text-cocoa">{n.body}</p>
          </article>
        ))
      }
      <div class="w-1 shrink-0 sm:w-4" aria-hidden="true"></div>
    </div>
    <p class="mx-auto mt-6 max-w-6xl px-6 text-xs text-stone lg:px-10">
      Attraction photography via Wikimedia Commons.
    </p>
  </section>

  <div class="py-20 lg:py-28"><CTABand /></div>
</Layout>

<script>
  const track = document.getElementById("attractions-track");
  const prev = document.querySelector('[data-scroll="prev"]');
  const next = document.querySelector('[data-scroll="next"]');
  const step = () => Math.min(track?.clientWidth ? track.clientWidth * 0.85 : 340, 360);
  prev?.addEventListener("click", () => track?.scrollBy({ left: -step(), behavior: "smooth" }));
  next?.addEventListener("click", () => track?.scrollBy({ left: step(), behavior: "smooth" }));
</script>

<style>
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .no-scrollbar::-webkit-scrollbar { display: none; }
</style>
