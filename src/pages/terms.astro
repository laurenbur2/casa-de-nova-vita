---
import Layout from "../layouts/Layout.astro";

const effectiveDate = "September 2025";

const sections = [
  {
    heading: "1. Our Religious Mission",
    body: [
      "Casa da Nova Vida is a faith-based religious organization dedicated to fostering spiritual growth, community, personal reflection, and religious practice through ceremonies, education, and other church activities.",
      "Information provided on this website is intended to educate visitors about our church, beliefs, and offerings. Nothing on this website should be interpreted as medical, psychological, or legal advice.",
    ],
  },
  {
    heading: "2. Religious Ceremonies",
    body: [
      "Certain church ceremonies may include the use of sacramental entheogenic plants or plant-based preparations as part of sincerely held religious beliefs and practices.",
      "Participation in any religious ceremony is voluntary and is available only in accordance with the Church's membership requirements, screening process, policies, and applicable law.",
      "Detailed participation requirements, informed consent, health disclosures, and ceremony guidelines are provided separately to eligible participants and are not part of these Website Terms.",
    ],
  },
  {
    heading: "3. Donations",
    body: [
      "Casa da Nova Vida is supported through voluntary donations and contributions from members and supporters.",
      "Suggested donations help support the Church's religious mission, ceremonies, educational programs, community services, facilities, and operational expenses.",
      "Donations are made in support of the Church's mission and are not payments for any product, sacrament, or guaranteed religious experience.",
      "Unless otherwise stated in writing, donations are non-refundable.",
      "If Casa da Nova Vida is recognized as a tax-exempt organization under applicable law, donations may be tax-deductible to the extent permitted by law. Donors should consult their own tax advisor regarding deductibility.",
    ],
  },
  {
    heading: "4. Website Use",
    body: ["You agree to use this website only for lawful purposes.", "You may not:"],
    list: [
      "Violate any applicable laws or regulations.",
      "Attempt to gain unauthorized access to the website or its systems.",
      "Upload malicious software or harmful code.",
      "Interfere with the operation or security of the website.",
      "Copy, reproduce, distribute, or commercially exploit website content without our prior written permission.",
    ],
    after: [
      "We reserve the right to restrict or terminate access to the website for violations of these Terms.",
    ],
  },
  {
    heading: "5. Intellectual Property",
    body: [
      "All content on this website, including text, graphics, photographs, logos, artwork, videos, downloadable materials, and other content, is the property of Casa da Nova Vida or is used with permission.",
      "No portion of this website may be copied, reproduced, modified, distributed, or used for commercial purposes without our prior written consent.",
    ],
  },
  {
    heading: "6. Educational and Wellness Information",
    body: [
      "The information presented on this website is provided for educational and informational purposes only.",
      "Descriptions of our ceremonies, spiritual practices, or community activities are not intended to diagnose, treat, cure, or prevent any medical or mental health condition, nor should they be considered a substitute for advice from qualified healthcare professionals.",
      "Individual experiences vary, and Casa da Nova Vida makes no guarantees regarding personal, spiritual, emotional, or physical outcomes.",
    ],
  },
  {
    heading: "7. Privacy",
    body: [
      "Your use of this website is also governed by our Privacy Policy.",
      "By using this website, you consent to the collection and use of information as described in that policy.",
    ],
  },
  {
    heading: "8. Third-Party Links",
    body: [
      "This website may contain links to third-party websites for informational purposes.",
      "Casa da Nova Vida is not responsible for the content, security, privacy practices, or availability of third-party websites.",
    ],
  },
  {
    heading: "9. Limitation of Liability",
    body: [
      "To the fullest extent permitted by applicable law, Casa da Nova Vida shall not be liable for any damages arising from your use of this website or reliance upon information contained on the website.",
      "Nothing in these Terms limits liability where such limitation is prohibited by law.",
    ],
  },
  {
    heading: "10. Changes to These Terms",
    body: [
      "We may update these Terms from time to time.",
      "Any revisions become effective upon posting to this website. Continued use of the website constitutes acceptance of the updated Terms.",
    ],
  },
  {
    heading: "11. Governing Law",
    body: [
      "These Terms shall be governed by and interpreted in accordance with the laws of the State of Texas, without regard to its conflict of law principles.",
    ],
  },
  {
    heading: "12. Severability",
    body: [
      "If any provision of these Terms is found to be unenforceable, the remaining provisions shall remain in full force and effect.",
    ],
  },
];
---

<Layout
  title="Terms & Conditions · Casa da Nova Vida"
  description="The Terms and Conditions governing your access to and use of the Casa da Nova Vida website."
>
  <!-- ===================== HEADER ===================== -->
  <section class="bg-pine px-6 pb-12 pt-28 sm:pb-14 sm:pt-32 lg:px-10 lg:pb-16 lg:pt-36">
    <div class="mx-auto max-w-3xl">
      <p class="eyebrow text-gold">Legal</p>
      <h1 class="mt-4 text-4xl leading-[1.1] text-linen sm:text-5xl">
        Website Terms &amp; Conditions
      </h1>
      <p class="mt-5 text-sm uppercase tracking-[0.18em] text-sagelight">
        Effective Date: {effectiveDate}
      </p>
    </div>
  </section>

  <!-- ===================== BODY ===================== -->
  <section class="px-6 py-12 sm:py-16 lg:px-10">
    <div class="mx-auto max-w-3xl">
      <p class="leading-relaxed text-cocoa">
        Welcome to Casa da Nova Vida (&ldquo;Casa da Nova Vida,&rdquo;
        &ldquo;Church,&rdquo; &ldquo;we,&rdquo; &ldquo;our,&rdquo; or
        &ldquo;us&rdquo;). These Terms and Conditions (&ldquo;Terms&rdquo;) govern
        your access to and use of our website, including any information,
        educational materials, events, retreats, membership inquiries, ceremonies,
        and other services offered through the website.
      </p>
      <p class="mt-5 leading-relaxed text-cocoa">
        By accessing or using this website, you agree to these Terms. If you do
        not agree, please discontinue use of the website.
      </p>

      {
        sections.map((s) => (
          <div class="mt-8 sm:mt-12">
            <h2 class="text-2xl text-pine">{s.heading}</h2>
            {s.body.map((p) => (
              <p class="mt-4 leading-relaxed text-cocoa">{p}</p>
            ))}
            {s.list && (
              <ul class="mt-4 space-y-2.5">
                {s.list.map((item) => (
                  <li class="flex gap-3 leading-relaxed text-cocoa">
                    <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-gold" aria-hidden="true" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
            {s.after &&
              s.after.map((p) => (
                <p class="mt-4 leading-relaxed text-cocoa">{p}</p>
              ))}
          </div>
        ))
      }

      <!-- Contact -->
      <div class="mt-8 sm:mt-12">
        <h2 class="text-2xl text-pine">13. Contact Us</h2>
        <p class="mt-4 leading-relaxed text-cocoa">
          If you have questions regarding these Terms or our Church, please
          contact us at:
        </p>
        <p class="mt-4 leading-relaxed text-cocoa">
          <span class="font-medium text-forest">Casa da Nova Vida</span><br />
          Email:
          <a
            href="mailto:info@casadanovavida.com"
            class="text-pine underline decoration-gold/60 underline-offset-4 transition-colors hover:text-forest"
            >info@casadanovavida.com</a
          >
        </p>
      </div>

      <!-- Acknowledgment -->
      <div class="mt-8 sm:mt-12 rounded-2xl border border-sand bg-parchment p-6 sm:p-8">
        <h2 class="text-2xl text-pine">Acknowledgment</h2>
        <p class="mt-4 leading-relaxed text-cocoa">
          By using this website, you acknowledge that you have read, understood,
          and agree to these Terms and Conditions.
        </p>
      </div>
    </div>
  </section>
</Layout>
