---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import { withBase } from "../lib/base";
import { DONATE_ENDPOINT } from "../lib/config";

// Where Stripe sends a donor after a successful gift (a dedicated thank-you
// page). Passed to the Worker, which uses it for the Checkout success_url.
const THANK_YOU_PATH = withBase("/thank-you");

// Donations run through Stripe Checkout, created on demand by the Worker
// (see ../lib/config.ts + ../../worker). This lets the exact amount — a preset,
// a custom value, or either of those plus the processing fee — show accurately
// at checkout, for both one-time and monthly gifts. The percent added when a
// donor opts to cover the fee must match FEE_RATE in the Worker.
const FEE_RATE = 0.03;

const amounts = ["20", "50", "100", "500"];

const supports = [
  {
    title: "Subsidizing a stay",
    body: "Your gift helps cover the cost of a guest's stay, making healing accessible to those who could not otherwise afford it.",
  },
  {
    title: "Community & program",
    body: "Donations fund program costs, community support services, and the charitable and religious operations of our church.",
  },
  {
    title: "The home itself",
    body: "Gifts help maintain the facilities and grounds in the Texas Hill Country that make this work of integration possible.",
  },
];

const faqs = [
  {
    q: "Is my donation tax-deductible?",
    a: "Yes. Casa da Nova Vida is a religious church that qualifies as tax-exempt under Section 501(c)(3) of the Internal Revenue Code (EIN 41-2320036). Contributions are generally tax-deductible to the extent allowed by law, and we provide a receipt for your records. Donations are not payments for goods or services; please consult your tax professional regarding deductibility.",
  },
  {
    q: "Where does my donation go?",
    a: "Your gift funds program costs, community support services, facilities, and financial assistance that helps make participation accessible to those in need, supporting the charitable and religious operations of the church.",
  },
  {
    q: "Can I volunteer or get more involved?",
    a: "Yes. We welcome those who wish to share their time and skills. Reach out to info@casadanovavida.com and we will find a way to plug you in.",
  },
  {
    q: "Do you accept in-kind donations?",
    a: "We do, and gratefully. If you would like to contribute goods or services rather than a financial gift, email info@casadanovavida.com to coordinate.",
  },
  {
    q: "Can I donate in honor or in memory of someone?",
    a: "Yes. You are welcome to make a gift in honor or in memory of a loved one. Just let us know at info@casadanovavida.com and we will make sure it is recognized.",
  },
];

// Turn any mention of our email in the FAQ answers into a clickable mailto
// link, so every email on the site behaves the same way.
const CONTACT_EMAIL = "info@casadanovavida.com";
const linkifyEmail = (text: string) =>
  text.replaceAll(
    CONTACT_EMAIL,
    `<a href="mailto:${CONTACT_EMAIL}" class="font-medium text-forest underline decoration-sage underline-offset-2 transition-colors hover:text-pine hover:decoration-forest">${CONTACT_EMAIL}</a>`,
  );
---

<Layout
  title="Donate · Casa da Nova Vida"
  description="Support Casa da Nova Vida. Your tax-deductible donation helps subsidize the cost of a person's stay and makes healing accessible to those in need."
>
  <PageHero
    eyebrow="Support Our Work"
    title="Help someone begin a new life"
    intro="Your gift supports our mission to bring a new path of healing to those in need. Every donation helps make this path of recovery and integration accessible to someone who could not otherwise afford it."
    image="/images/photos/property-sunset-hills.png"
    imageAlt="Golden-hour sun setting over the rolling Texas Hill Country"
  />

  <!-- ===================== DONATION FORM ===================== -->
  <section class="px-6 py-20 lg:px-10 lg:py-24">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[1fr_1fr] lg:items-start">
      <!-- Left: the ask -->
      <div>
        <p class="eyebrow">Why give</p>
        <h2 class="mt-4 text-3xl text-pine sm:text-4xl">
          A gift that lands where it's needed most
        </h2>
        <p class="mt-6 leading-relaxed text-cocoa">
          Casa da Nova Vida is a church devoted to healing and spiritual
          renewal. We keep our doors open to people walking an alternative path
          of healing, regardless of what they can pay. Your generosity is often
          the difference between someone facing the vulnerable days after
          treatment alone, or being held by a community.
        </p>

        <div class="mt-10 space-y-6">
          {
            supports.map((s) => (
              <div class="flex gap-4">
                <span class="mt-1.5 h-2 w-2 flex-none rounded-full bg-clay" />
                <div>
                  <h3 class="text-lg text-forest">{s.title}</h3>
                  <p class="mt-1 leading-relaxed text-cocoa">{s.body}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Right: donation card -->
      <div
        id="donate-card"
        class="rounded-3xl border border-sand bg-parchment p-8 shadow-sm lg:p-10"
        data-donate-endpoint={DONATE_ENDPOINT}
        data-thankyou-path={THANK_YOU_PATH}
        data-fee-rate={FEE_RATE}
      >
        <h2 class="text-2xl text-pine">Make a donation</h2>

        <!-- Return banners (shown after Stripe redirects back) -->
        <div
          id="donate-success"
          hidden
          role="status"
          class="mt-6 rounded-2xl border border-sage/40 bg-cream p-5 text-sm leading-relaxed text-forest"
        >
          <strong class="text-pine">Thank you for your gift.</strong> Your donation
          went through — a receipt is on its way. We're grateful for your support.
        </div>
        <div
          id="donate-cancelled"
          hidden
          role="status"
          class="mt-6 rounded-2xl border border-sand bg-cream p-5 text-sm leading-relaxed text-cocoa"
        >
          No charge was made — your checkout was cancelled. Whenever you're ready,
          your gift is welcome.
        </div>

        <!-- Frequency toggle -->
        <div class="mt-6">
          <span class="text-xs uppercase tracking-[0.18em] text-stone">Frequency</span>
          <div
            id="freq-group"
            class="mt-3 grid grid-cols-2 gap-2 rounded-full border border-sand bg-cream p-1"
            role="tablist"
            aria-label="Donation frequency"
          >
            <button
              type="button"
              data-freq="once"
              class="freq-btn is-active rounded-full py-2.5 text-sm font-medium transition-colors"
              aria-selected="true"
            >
              One-time
            </button>
            <button
              type="button"
              data-freq="monthly"
              class="freq-btn rounded-full py-2.5 text-sm font-medium transition-colors"
              aria-selected="false"
            >
              Monthly
            </button>
          </div>
        </div>

        <!-- Amount grid -->
        <div class="mt-7">
          <span class="text-xs uppercase tracking-[0.18em] text-stone">Amount</span>
          <div class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-4">
            {
              amounts.map((a, i) => (
                <button
                  type="button"
                  data-amount={a}
                  class:list={[
                    "amount-btn rounded-xl border py-3.5 text-lg font-medium transition-colors",
                    i === 1
                      ? "is-active border-pine bg-pine text-linen"
                      : "border-sand bg-linen text-forest hover:border-moss",
                  ]}
                  aria-pressed={i === 1 ? "true" : "false"}
                >
                  ${a}
                </button>
              ))
            }
          </div>
          <button
            type="button"
            id="custom-btn"
            data-amount="custom"
            class="amount-btn mt-3 w-full rounded-xl border border-dashed border-sand bg-linen py-3.5 text-base font-medium text-forest transition-colors hover:border-moss"
            aria-pressed="false"
          >
            Choose a custom amount
          </button>

          <!-- Custom amount input (revealed when "custom" is selected) -->
          <div id="custom-wrap" hidden class="mt-3">
            <label class="block text-xs uppercase tracking-[0.18em] text-stone" for="custom-amount">
              Your amount
            </label>
            <div class="mt-2 flex items-center rounded-xl border border-sand bg-linen focus-within:border-moss">
              <span class="pl-4 text-lg text-stone">$</span>
              <input
                id="custom-amount"
                type="number"
                inputmode="decimal"
                min="1"
                step="1"
                placeholder="Enter an amount"
                class="w-full bg-transparent px-2 py-3.5 text-lg text-forest outline-none"
              />
            </div>
          </div>
        </div>

        <!-- Cover the fee -->
        <label class="mt-6 flex items-start gap-3 text-sm text-cocoa">
          <input
            type="checkbox"
            id="cover-fee"
            class="mt-0.5 h-4 w-4 flex-none rounded border-sand text-pine focus:ring-moss/30"
          />
          <span>
            Add <span id="fee-pct">3%</span> to cover the card processing fee, so
            your full gift reaches our guests. The exact total is shown on the
            button and at checkout.
          </span>
        </label>

        <!-- CTA -->
        <button
          id="donate-cta"
          type="button"
          class="mt-7 flex w-full items-center justify-center rounded-full bg-pine px-7 py-4 font-medium text-linen transition-colors hover:bg-forest disabled:cursor-not-allowed disabled:opacity-60"
        >
          <span id="donate-cta-label">Donate $50</span>
        </button>
        <p
          id="donate-error"
          hidden
          role="alert"
          class="mt-4 rounded-xl border border-clay/40 bg-clay/10 px-4 py-3 text-center text-sm text-clay"
        >
        </p>
        <p class="mt-4 text-center text-xs leading-relaxed text-stone">
          Secure checkout via Stripe. You'll be able to review your gift before
          confirming.
        </p>
      </div>
    </div>
  </section>

  <!-- ===================== FAQ ===================== -->
  <section class="border-t border-sand bg-cream px-6 py-20 lg:px-10 lg:py-24">
    <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.9fr_1.3fr] lg:gap-16">
      <div>
        <p class="eyebrow">FAQ</p>
        <h2 class="mt-4 text-3xl text-pine sm:text-4xl">
          Frequently asked questions
        </h2>
      </div>
      <div class="border-t border-sand">
        {
          faqs.map((f) => (
            <details class="faq border-b border-sand">
              <summary class="flex cursor-pointer items-center justify-between gap-4 py-5 text-lg text-forest">
                {f.q}
                <span class="faq-plus flex-none text-pine transition-transform duration-300">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
                    <path d="M12 5v14M5 12h14" />
                  </svg>
                </span>
              </summary>
              <p class="pb-5 leading-relaxed text-cocoa" set:html={linkifyEmail(f.a)} />
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== OTHER WAYS TO GIVE ===================== -->
  <section class="px-6 py-20 lg:px-10 lg:py-24">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">Other ways to give</p>
      <h2 class="mt-4 text-3xl text-pine sm:text-4xl">
        Not every gift is financial
      </h2>
      <p class="mt-6 leading-relaxed text-cocoa">
        We gratefully accept in-kind donations, and we welcome those who wish to
        offer their time and skills as volunteers. If you'd like to contribute in
        another way, we'd love to hear from you.
      </p>
      <a
        href="mailto:info@casadanovavida.com"
        class="mt-8 inline-flex rounded-full border border-moss/50 px-8 py-4 font-medium text-pine transition-colors hover:border-moss hover:bg-cream"
      >
        Email info@casadanovavida.com
      </a>
    </div>
  </section>
</Layout>

<script>
  const card = document.getElementById("donate-card");
  const cta = document.getElementById("donate-cta") as HTMLButtonElement | null;
  const ctaLabel = document.getElementById("donate-cta-label");
  const errorEl = document.getElementById("donate-error");
  const coverFee = document.getElementById("cover-fee") as HTMLInputElement | null;
  const customWrap = document.getElementById("custom-wrap");
  const customInput = document.getElementById("custom-amount") as HTMLInputElement | null;
  const freqBtns = Array.from(document.querySelectorAll<HTMLButtonElement>(".freq-btn"));
  const amountBtns = Array.from(document.querySelectorAll<HTMLButtonElement>(".amount-btn"));

  if (card && cta && ctaLabel) {
    const endpoint = card.dataset.donateEndpoint || "";
    const thankYouPath = card.dataset.thankyouPath || "";
    const feeRate = Number(card.dataset.feeRate) || 0.03;

    const pctEl = document.getElementById("fee-pct");
    if (pctEl) pctEl.textContent = `${Math.round(feeRate * 100)}%`;

    let freq: "once" | "monthly" = "once";
    let amount = "50"; // one of the presets, or "custom"

    // Dollar amount before the optional fee, or null when custom is empty/invalid.
    const baseAmount = (): number | null => {
      if (amount !== "custom") return Number(amount);
      const v = Number(customInput?.value);
      return Number.isFinite(v) && v >= 1 ? v : null;
    };

    const fmt = (n: number) => {
      const r = Math.round(n * 100) / 100;
      return Number.isInteger(r) ? `$${r}` : `$${r.toFixed(2)}`;
    };

    const setActive = (list: HTMLButtonElement[], match: (b: HTMLButtonElement) => boolean, on: string, off: string) => {
      list.forEach((b) => {
        const active = match(b);
        on.split(" ").forEach((c) => b.classList.toggle(c, active));
        off.split(" ").forEach((c) => b.classList.toggle(c, !active));
      });
    };

    const sync = () => {
      if (customWrap) customWrap.hidden = amount !== "custom";

      const base = baseAmount();
      const suffix = freq === "monthly" ? "/mo" : "";

      if (base === null) {
        ctaLabel.textContent = "Enter an amount";
        cta.disabled = true;
        return;
      }
      cta.disabled = false;
      const total = coverFee?.checked ? base * (1 + feeRate) : base;
      ctaLabel.textContent = `Donate ${fmt(total)}${suffix}`;
    };

    freqBtns.forEach((b) =>
      b.addEventListener("click", () => {
        freq = (b.dataset.freq as "once" | "monthly") || "once";
        freqBtns.forEach((x) => {
          const active = x === b;
          x.classList.toggle("is-active", active);
          x.setAttribute("aria-selected", String(active));
        });
        sync();
      }),
    );

    amountBtns.forEach((b) =>
      b.addEventListener("click", () => {
        amount = b.dataset.amount || "50";
        setActive(
          amountBtns,
          (x) => x.dataset.amount === amount,
          "is-active border-pine bg-pine text-linen",
          "border-sand bg-linen text-forest",
        );
        amountBtns.forEach((x) => x.setAttribute("aria-pressed", String(x.dataset.amount === amount)));
        if (amount === "custom") customInput?.focus();
        sync();
      }),
    );

    customInput?.addEventListener("input", sync);
    coverFee?.addEventListener("change", sync);

    cta.addEventListener("click", async () => {
      const base = baseAmount();
      if (base === null) {
        customInput?.focus();
        return;
      }
      if (errorEl) errorEl.hidden = true;
      cta.disabled = true;
      const label = ctaLabel.textContent;
      ctaLabel.textContent = "Redirecting…";

      try {
        const res = await fetch(endpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            amount: base,
            coverFee: !!coverFee?.checked,
            frequency: freq,
            returnTo: location.origin + location.pathname,
            successTo: thankYouPath ? location.origin + thankYouPath : undefined,
          }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data.url) throw new Error(data.error || "Could not start checkout.");
        window.location.href = data.url;
      } catch (err) {
        if (errorEl) {
          errorEl.textContent =
            err instanceof Error ? err.message : "Something went wrong. Please try again.";
          errorEl.hidden = false;
        }
        cta.disabled = false;
        ctaLabel.textContent = label || "Donate";
      }
    });

    sync();

    // Show a banner when Stripe redirects back, then clean the URL.
    const status = new URLSearchParams(location.search).get("donation");
    if (status === "success" || status === "cancelled") {
      const banner = document.getElementById(
        status === "success" ? "donate-success" : "donate-cancelled",
      );
      if (banner) {
        banner.hidden = false;
        banner.scrollIntoView({ behavior: "smooth", block: "center" });
      }
      history.replaceState(null, "", location.origin + location.pathname);
    }
  }
</script>

<style>
  .freq-btn { color: var(--color-cocoa); }
  .freq-btn.is-active {
    background-color: var(--color-linen);
    color: var(--color-pine);
    box-shadow: 0 1px 2px rgba(43, 54, 70, 0.12);
  }

  .faq summary { list-style: none; }
  .faq summary::-webkit-details-marker { display: none; }
  .faq[open] .faq-plus { transform: rotate(45deg); }
</style>
