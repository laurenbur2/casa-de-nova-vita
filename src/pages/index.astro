---
import Layout from "../layouts/Layout.astro";
import CTABand from "../components/CTABand.astro";
import { withBase } from "../lib/base";

const program = [
  {
    title: "Healing Modalities",
    icon: "m12 21.35l-1.45-1.32C5.4 15.36 2 12.27 2 8.5C2 5.41 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.08C13.09 3.81 14.76 3 16.5 3C19.58 3 22 5.41 22 8.5c0 3.77-3.4 6.86-8.55 11.53z",
    body: "Entheogenic plant medicines, integration coaching, CBT, acupuncture and herbalism, craniosacral therapy, sound healing, and massage.",
  },
  {
    title: "Integration",
    icon: "M11.43 9.67c.04.11.07.21.07.33v5.22c0 .5-.19.98-.53 1.35l-2.79 3.05l-3.4-3.4L6 15L8.8 2.86a1.114 1.114 0 0 1 2.2.25v4.96a2 2 0 0 0-.5-.07c-1.1 0-2 .9-2 2v3c0 .28.22.5.5.5s.5-.22.5-.5v-3c0-.55.45-1 1-1c.19 0 .35.07.5.16c.12.07.21.16.3.26c.03.04.06.08.08.13c.02.04.04.08.05.12M2 19l4 3l1.17-1.27l-3.45-3.45zm16-4L15.2 2.86a1.114 1.114 0 0 0-2.2.25v4.96c.16-.04.33-.07.5-.07c1.1 0 2 .9 2 2v3c0 .28-.22.5-.5.5s-.5-.22-.5-.5v-3c0-.55-.45-1-1-1c-.19 0-.35.07-.5.16c-.12.07-.21.16-.29.26c-.03.04-.07.08-.09.13c-.02.04-.04.08-.05.12c-.04.11-.07.21-.07.33v5.22c0 .5.19.98.53 1.35l2.79 3.05l3.4-3.4zm2.28 2.28l-3.45 3.45L18 22l4-3z",
    body: "1-on-1 coaching, meditation and mindfulness, prayer practice, nutrition, and healthy lifestyle instruction for lasting growth.",
  },
  {
    title: "Supportive Community",
    icon: "M12 5.5A3.5 3.5 0 0 1 15.5 9a3.5 3.5 0 0 1-3.5 3.5A3.5 3.5 0 0 1 8.5 9A3.5 3.5 0 0 1 12 5.5M5 8c.56 0 1.08.15 1.53.42c-.15 1.43.27 2.85 1.13 3.96C7.16 13.34 6.16 14 5 14a3 3 0 0 1-3-3a3 3 0 0 1 3-3m14 0a3 3 0 0 1 3 3a3 3 0 0 1-3 3c-1.16 0-2.16-.66-2.66-1.62a5.54 5.54 0 0 0 1.13-3.96c.45-.27.97-.42 1.53-.42M5.5 18.25c0-2.07 2.91-3.75 6.5-3.75s6.5 1.68 6.5 3.75V20h-13zM0 20v-1.5c0-1.39 1.89-2.56 4.45-2.9c-.59.68-.95 1.62-.95 2.65V20zm24 0h-3.5v-1.75c0-1.03-.36-1.97-.95-2.65c2.56.34 4.45 1.51 4.45 2.9z",
    body: "Experienced mentors, guides, practitioners, and therapists holding a nurturing environment built for healing and recovery.",
  },
];

const who = [
  {
    title: "Post Plant Medicine Treatment",
    body: "A grounded place to land after Ibogaine or Ayahuasca, and integrate those profound experiences into long-lasting change.",
    img: "/images/photos/cards/welcome-land.jpg",
    alt: "A quiet home resting in a golden Hill Country meadow",
  },
  {
    title: "Seeking an Alternative Path",
    body: "For those conventional 12-step programs haven't served, an earth-medicine path to the root cause of addiction.",
    img: "/images/photos/cards/welcome-path.jpg",
    alt: "Ancient cypress roots along clear spring-fed water",
  },
  {
    title: "Otherwise Ready to Heal",
    body: "It's not only those in addiction who need healing. Our doors are open to anyone seeking space and time to grow.",
    img: "/images/photos/cards/welcome-grow.jpg",
    alt: "The sun setting over open rolling hills",
  },
];
---

<Layout>
  <!-- ===================== HERO ===================== -->
  <section
    class="relative isolate flex min-h-screen items-center justify-end overflow-hidden bg-bark"
  >
    <video
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster={withBase("/videos/casa-hero-poster.jpg")}
    >
      <source src={withBase("/videos/casa-hero.mp4")} type="video/mp4" />
    </video>
    <div class="absolute inset-0 -z-10 bg-bark/25"></div>
    <div
      class="absolute inset-0 -z-10 bg-gradient-to-b from-bark/50 via-bark/10 to-bark/60"
    >
    </div>

    <div
      class="mx-auto max-w-2xl px-6 pt-[18vh] text-center [text-shadow:0_2px_24px_rgba(20,26,36,0.45)]"
    >
      <p class="eyebrow rise text-gold">Casa da Nova Vida</p>
      <h1
        class="rise rise-2 mt-5 text-balance text-3xl font-light leading-[1.1] text-linen sm:text-4xl lg:text-5xl"
      >
        House of Healing &amp; <span class="italic text-sagelight">Integration</span>
      </h1>
      <p
        class="rise rise-3 mx-auto mt-5 max-w-lg text-sm leading-relaxed text-cream/90 sm:text-base"
      >
        A recovery house for those on an alternative path of healing and
        integration through spiritual realization.
      </p>
      <div
        class="rise rise-4 mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
      >
        <a
          href={withBase("/contact")}
          class="w-full rounded-full bg-linen px-6 py-3 text-center text-sm font-medium text-pine transition-colors hover:bg-cream sm:w-auto"
        >
          Begin the Conversation
        </a>
        <a
          href={withBase("/our-approach")}
          class="w-full rounded-full border border-cream/50 px-6 py-3 text-center text-sm font-medium text-linen backdrop-blur-sm transition-colors hover:border-cream hover:bg-linen/10 sm:w-auto"
        >
          Explore Our Approach
        </a>
      </div>
    </div>

    <a
      href="#intro"
      aria-label="Scroll to explore"
      class="scroll-cue absolute bottom-8 left-1/2 hidden h-12 w-12 -translate-x-1/2 items-center justify-center rounded-full border border-dotted border-cream/50 text-cream/80 transition-colors hover:border-cream hover:text-linen sm:flex"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 5v14M6 13l6 6 6-6" />
      </svg>
    </a>
  </section>

  <!-- ===================== INTRO STATEMENT ===================== -->
  <section id="intro" class="scroll-mt-24 px-6 py-24 lg:px-10 lg:py-32">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">Because we've been there</p>
      <p
        class="mt-8 font-display text-2xl leading-[1.5] text-cocoa sm:text-3xl sm:leading-[1.5]"
      >
        We understand the pain and hopelessness that accompany addiction. At Nova
        Vida, we offer an alternative, holistic path to recovery, with a deep
        emphasis on <span class="text-pine">spiritual development</span> and working
        with sacrament.
      </p>
    </div>
  </section>

  <!-- ===================== THE PLACE (image band) ===================== -->
  <section class="relative isolate overflow-hidden">
    <img
      src={withBase("/images/photos/property-porch-firepit.png")}
      alt="Covered porch with a fire pit overlooking the Texas Hill Country"
      class="absolute inset-0 -z-10 h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-bark/55"></div>
    <div
      class="mx-auto flex min-h-[70vh] max-w-6xl flex-col justify-center px-6 py-28 text-linen lg:px-10"
    >
      <div class="max-w-xl [text-shadow:0_2px_20px_rgba(20,26,36,0.5)]">
        <p class="eyebrow text-gold">Just outside Austin, TX</p>
        <h2 class="mt-5 text-3xl leading-tight sm:text-4xl lg:text-5xl">
          A serene home in the Texas Hill Country
        </h2>
        <p class="mt-6 max-w-md leading-relaxed text-cream/90">
          Spring-fed waters, hiking trails, and wide open skies aren't a backdrop
          to the healing here. They're part of it.
        </p>
        <a
          href={withBase("/our-location")}
          class="mt-8 inline-flex items-center gap-2 rounded-full border border-cream/60 px-6 py-3 text-sm font-medium text-linen backdrop-blur-sm transition-colors hover:border-cream hover:bg-linen/10"
        >
          See our location
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== OUR PROGRAM ===================== -->
  <section class="px-6 py-24 lg:px-10 lg:py-32">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Our Program</p>
        <h2 class="mt-4 text-3xl text-pine sm:text-4xl">
          A comprehensive path, tended with care
        </h2>
      </div>
      <div class="mt-16 grid gap-6 md:grid-cols-3">
        {
          program.map((p) => (
            <div class="group rounded-3xl border border-sand bg-parchment p-8 transition-all duration-300 hover:-translate-y-1 hover:border-sage hover:shadow-[0_18px_50px_-24px_rgba(43,54,70,0.35)] lg:p-10">
              <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-cream to-sage/40 text-pine ring-1 ring-sand transition-colors group-hover:from-sage/30 group-hover:to-pine/10">
                <svg viewBox="0 0 24 24" class="h-8 w-8" fill="currentColor" aria-hidden="true">
                  <path d={p.icon} />
                </svg>
              </div>
              <h3 class="mt-7 text-xl text-forest">{p.title}</h3>
              <p class="mt-3 leading-relaxed text-cocoa">{p.body}</p>
            </div>
          ))
        }
      </div>
      <div class="mt-16 text-center">
        <a
          href={withBase("/our-program")}
          class="inline-flex rounded-full bg-pine px-8 py-4 font-medium text-linen transition-colors hover:bg-forest"
        >
          Explore the program
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== WHO WE RECEIVE ===================== -->
  <section class="border-y border-sand bg-parchment px-6 py-24 lg:px-10 lg:py-32">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Who we welcome</p>
        <h2 class="mt-4 text-3xl text-pine sm:text-4xl">
          A home for those the medicine has called forward
        </h2>
      </div>
      <div class="mt-16 grid gap-6 md:grid-cols-3">
        {
          who.map((c) => (
            <article class="group relative isolate overflow-hidden rounded-3xl shadow-sm ring-1 ring-sand/60 transition-shadow duration-300 hover:shadow-[0_24px_60px_-28px_rgba(43,54,70,0.5)]">
              <img
                src={withBase(c.img)}
                alt={c.alt}
                class="h-[26rem] w-full object-cover transition-transform duration-[900ms] ease-out group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-bark/90 via-bark/45 to-bark/5" />
              <div class="absolute inset-x-0 bottom-0 p-7 lg:p-8">
                <h3 class="text-2xl leading-snug text-linen [text-shadow:0_1px_12px_rgba(20,26,36,0.5)]">
                  {c.title}
                </h3>
                <p class="mt-2.5 text-sm leading-relaxed text-cream/90">{c.body}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== AFTERCARE (image band) ===================== -->
  <section class="relative isolate overflow-hidden">
    <img
      src={withBase("/images/photos/forest-light-rays.png")}
      alt="Sunlight breaking through a forest canopy"
      class="absolute inset-0 -z-10 h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 -z-10 bg-pine/75"></div>
    <div
      class="mx-auto max-w-3xl px-6 py-28 text-center text-linen lg:px-10 lg:py-36 [text-shadow:0_2px_20px_rgba(20,26,36,0.5)]"
    >
      <p class="eyebrow text-gold">The Importance of Aftercare</p>
      <p class="mt-8 font-display text-2xl leading-[1.5] sm:text-3xl sm:leading-[1.5]">
        The days after treatment are a critical, vulnerable window. Aftercare
        isn't an afterthought. It's the bridge between revelation and a truly
        renewed way of being.
      </p>
      <a
        href={withBase("/ibogaine-aftercare")}
        class="mt-10 inline-flex rounded-full bg-linen px-8 py-4 font-medium text-pine transition-colors hover:bg-cream"
      >
        Ibogaine Aftercare
      </a>
    </div>
  </section>

  <div class="py-24 lg:py-32">
    <CTABand />
  </div>
</Layout>
