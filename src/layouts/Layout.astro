---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { withBase } from "../lib/base";

interface Props {
  title?: string;
  description?: string;
  /** Path or absolute URL to the social-share image. */
  image?: string;
  /** Extra JSON-LD to inject on this page (e.g. FAQPage, Article). */
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "Casa da Nova Vida · A Sanctuary for Healing & Integration",
  description = "A serene Texas Hill Country sanctuary for integration after Ibogaine and plant-medicine work. Grounded aftercare through coaching, lifestyle, and sacrament.",
  image = "/images/og-card.png",
  schema,
} = Astro.props;

const siteOrigin = Astro.site ?? new URL("https://casadanovavida.com");
const canonical = new URL(Astro.url.pathname, siteOrigin);
const ogImage = new URL(withBase(image), siteOrigin);

// Sitewide organization schema. Casa da Nova Vida is a religious church and an
// aftercare/integration sanctuary — deliberately NOT typed as a medical entity,
// matching the site's own disclaimer that it does not provide medical treatment.
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Casa da Nova Vida",
  alternateName: "Casa da Nova Vida · House of Healing",
  url: siteOrigin.href,
  logo: new URL(withBase("/images/logo/mark-navy.png"), siteOrigin).href,
  description:
    "A Texas Hill Country sanctuary for healing and integration after Ibogaine and plant-medicine work, offering grounded aftercare through coaching, community, and spiritual practice.",
  email: "info@casadanovavida.com",
  telephone: "+1-512-222-7752",
  areaServed: "US",
  address: {
    "@type": "PostalAddress",
    addressRegion: "TX",
    addressCountry: "US",
  },
  sameAs: [
    "https://www.instagram.com/casadanovavida/",
    "https://www.facebook.com/novavidahoh/",
  ],
};

const schemas = [orgSchema, ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={withBase("/favicon.png")} />
    <link rel="apple-touch-icon" href={withBase("/favicon.png")} />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Casa da Nova Vida" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Casa da Nova Vida" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data -->
    {
      schemas.map((s) => (
        <script type="application/ld+json" set:html={JSON.stringify(s)} />
      ))
    }

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-pine focus:px-4 focus:py-2 focus:text-linen"
      >Skip to content</a
    >
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <!-- Email links: copy the address to the clipboard on click and confirm,
         so a click always does something even when no mail app is configured. -->
    <script>
      document.querySelectorAll('a[href^="mailto:"]').forEach((a) => {
        a.addEventListener("click", async () => {
          const email = (a.getAttribute("href") || "")
            .replace(/^mailto:/, "")
            .split("?")[0];
          if (!email) return;
          let copied = false;
          try {
            if (navigator.clipboard) {
              await navigator.clipboard.writeText(email);
              copied = true;
            }
          } catch {}
          if (!copied) {
            try {
              const ta = document.createElement("textarea");
              ta.value = email;
              ta.style.position = "fixed";
              ta.style.opacity = "0";
              document.body.appendChild(ta);
              ta.select();
              copied = document.execCommand("copy");
              ta.remove();
            } catch {}
          }
          if (!copied) return;
          const toast = document.createElement("div");
          toast.textContent = "Email copied to clipboard";
          toast.className = "email-toast";
          document.body.appendChild(toast);
          requestAnimationFrame(() => toast.classList.add("is-visible"));
          setTimeout(() => {
            toast.classList.remove("is-visible");
            setTimeout(() => toast.remove(), 300);
          }, 1800);
        });
      });
    </script>
  </body>
</html>
