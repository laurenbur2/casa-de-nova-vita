---
import { withBase } from "../lib/base";
const year = new Date().getFullYear();
const links = [
  { href: "/our-story", label: "Our Story" },
  { href: "/our-approach", label: "Our Approach" },
  { href: "/our-program", label: "Our Program" },
  { href: "/ibogaine-aftercare", label: "Ibogaine Aftercare" },
  { href: "/recovery", label: "Recovery" },
  { href: "/for-families", label: "For Families" },
  { href: "/resources", label: "Resources" },
  { href: "/our-location", label: "Our Location" },
  { href: "/contact", label: "Contact" },
  { href: "/donate", label: "Donate" },
];
---

<footer class="relative mt-0 overflow-hidden bg-pine text-linen">
  <img
    src={withBase("/images/logo/mark-cream.png")}
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-16 right-0 w-80 opacity-[0.05]"
  />
  <div class="relative mx-auto max-w-7xl px-6 py-16 lg:px-10">
    <div class="grid gap-12 md:grid-cols-[1.4fr_1fr_1fr]">
      <div>
        <div class="flex items-center gap-3">
          <img
            src={withBase("/images/logo/mark-cream.png")}
            alt="Casa da Nova Vida hummingbird emblem"
            class="h-12 w-12 object-contain"
            width="512"
            height="506"
          />
          <span class="font-display text-xl">Casa da Nova Vida</span>
        </div>
        <p class="mt-5 max-w-sm text-sm leading-relaxed text-sagelight">
          A sanctuary for healing and integration in the Texas Hill Country,
          grounding the teachings of the medicine into a new life, one honest
          day at a time.
        </p>
        <div class="mt-6 flex gap-3">
          <a
            href="https://www.instagram.com/casadanovavida/"
            target="_blank"
            rel="noopener"
            aria-label="Follow us on Instagram"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-sage/30 text-sagelight transition-colors hover:border-linen hover:text-linen"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" stroke="none" />
            </svg>
          </a>
          <a
            href="https://www.facebook.com/novavidahoh/"
            target="_blank"
            rel="noopener"
            aria-label="Follow us on Facebook"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-sage/30 text-sagelight transition-colors hover:border-linen hover:text-linen"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.51 1.49-3.9 3.77-3.9c1.1 0 2.24.2 2.24.2v2.47h-1.26c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.44 2.9h-2.34V22c4.78-.76 8.44-4.92 8.44-9.94z" />
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-xs uppercase tracking-[0.2em] text-sage">Explore</h3>
        <ul class="mt-4 space-y-2.5 text-sm">
          {
            links.map((l) => (
              <li>
                <a
                  href={withBase(l.href)}
                  class="text-sagelight transition-colors hover:text-linen"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="text-xs uppercase tracking-[0.2em] text-sage">Reach Us</h3>
        <ul class="mt-4 space-y-2.5 text-sm text-sagelight">
          <li>
            <a href="tel:+15122227752" class="transition-colors hover:text-linen"
              >(512) 222-7752</a
            >
          </li>
          <li>
            <a
              href="mailto:info@casadanovavida.com"
              class="transition-colors hover:text-linen"
              >info@casadanovavida.com</a
            >
          </li>
          <li class="pt-1 leading-relaxed">Texas Hill Country<br />Outside Austin, TX</li>
        </ul>
      </div>
    </div>

    <div
      class="mt-14 flex flex-col gap-3 border-t border-sage/25 pt-6 text-xs text-sage sm:flex-row sm:items-center sm:justify-between"
    >
      <p>&copy; {year} Casa da Nova Vida. All rights reserved.</p>
      <p class="max-w-xl leading-relaxed">
        Casa da Nova Vida is a religious church offering an alternative, holistic
        path of healing and integration. We do not administer Ibogaine or provide
        medical treatment, and nothing here is medical advice.
      </p>
    </div>
  </div>
</footer>
