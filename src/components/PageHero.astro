---
import { withBase } from "../lib/base";
interface Props {
  eyebrow: string;
  title: string;
  intro?: string;
  image: string;
  imageAlt: string;
}
const { eyebrow, title, intro, image, imageAlt } = Astro.props;
---

<section class="relative isolate overflow-hidden bg-pine">
  <img
    src={withBase(image)}
    alt={imageAlt}
    class="absolute inset-0 -z-10 h-full w-full object-cover opacity-60"
    loading="eager"
  />
  <div class="absolute inset-0 -z-10 bg-gradient-to-br from-pine/70 via-pine/50 to-forest/65"></div>
  <div class="mx-auto max-w-7xl px-6 pb-24 pt-32 lg:px-10 lg:pb-32 lg:pt-44">
    <p class="eyebrow rise text-gold">{eyebrow}</p>
    <h1 class="rise rise-2 mt-5 max-w-3xl text-4xl leading-[1.1] text-linen sm:text-5xl">
      {title}
    </h1>
    {
      intro && (
        <p class="rise rise-3 mt-6 max-w-2xl text-lg leading-relaxed text-cream/90">
          {intro}
        </p>
      )
    }
  </div>
</section>
