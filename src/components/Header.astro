---
import { withBase } from "../lib/base";
const links = [
  { href: "/our-story", label: "Our Story" },
  { href: "/our-approach", label: "Our Approach" },
  { href: "/our-program", label: "Our Program" },
  { href: "/ibogaine-aftercare", label: "Ibogaine Aftercare" },
  { href: "/resources", label: "Resources" },
  { href: "/our-location", label: "Our Location" },
];
const path = Astro.url.pathname;
const isActive = (href: string) =>
  path === withBase(href) || path === withBase(href) + "/";
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-40 border-b border-transparent transition-colors duration-300"
>
  <nav
    class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-4 lg:px-10"
    aria-label="Primary"
  >
    <a href={withBase("/")} class="group flex items-center gap-3">
      <img
        class="logo-light h-12 w-12 object-contain"
        src={withBase("/images/logo/mark-cream.png")}
        alt="Casa da Nova Vida hummingbird emblem"
        width="512"
        height="506"
      />
      <img
        class="logo-dark hidden h-12 w-12 object-contain"
        src={withBase("/images/logo/mark-navy.png")}
        alt=""
        aria-hidden="true"
        width="512"
        height="506"
      />
      <span class="hidden flex-col leading-none sm:flex">
        <span class="brand font-display text-lg text-linen">Casa da Nova Vida</span>
        <span class="brand-sub text-[0.66rem] uppercase tracking-[0.22em] text-cream/70"
          >House of Healing</span
        >
      </span>
    </a>

    <div class="hidden items-center gap-5 xl:flex">
      {
        links.map((l) => (
          <a
            href={withBase(l.href)}
            class:list={["nav-link whitespace-nowrap text-sm transition-colors", isActive(l.href) && "is-current"]}
          >
            {l.label}
          </a>
        ))
      }
      <a
        href={withBase("/contact")}
        class="header-cta whitespace-nowrap rounded-full px-5 py-2.5 text-sm font-medium transition-colors"
      >
        Begin the Conversation
      </a>
      <a
        href={withBase("/donate")}
        class="donate-cta rounded-full px-5 py-2.5 text-sm font-semibold transition-colors"
      >
        Donate
      </a>
    </div>

    <!-- Always-visible Donate + menu on smaller screens -->
    <div class="flex items-center gap-3 xl:hidden">
      <a
        href={withBase("/donate")}
        class="donate-cta rounded-full px-4 py-2 text-sm font-semibold transition-colors"
      >
        Donate
      </a>
      <button
        id="menu-toggle"
        class="menu-btn -mr-2 p-2 text-linen"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Backdrop -->
<div
  id="menu-backdrop"
  class="fixed inset-0 z-40 bg-bark/50 opacity-0 pointer-events-none transition-opacity duration-300 xl:hidden"
>
</div>

<!-- Slide-in drawer -->
<aside
  id="mobile-menu"
  class="fixed right-0 top-0 z-50 flex h-screen w-[84%] max-w-sm translate-x-full flex-col bg-parchment shadow-2xl transition-transform duration-300 ease-out xl:hidden"
    aria-hidden="true"
    aria-label="Menu"
  >
    <div class="flex items-center justify-between px-7 pt-6">
      <div class="flex items-center gap-2.5">
        <img
          src={withBase("/images/logo/mark-navy.png")}
          alt=""
          aria-hidden="true"
          class="h-9 w-9 object-contain"
        />
        <span class="font-display text-lg text-pine">Casa da Nova Vida</span>
      </div>
      <button
        id="menu-close"
        class="-mr-1 p-2 text-cocoa transition-colors hover:text-pine"
        aria-label="Close menu"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <path d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>

    <nav class="mt-6 flex flex-col px-7" aria-label="Mobile">
      {
        links.map((l) => (
          <a
            href={withBase(l.href)}
            class="border-b border-sand/70 py-4 font-display text-2xl text-pine transition-colors hover:text-forest"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="mt-auto space-y-3 px-7 pb-9 pt-8">
      <a
        href={withBase("/contact")}
        class="block rounded-full border border-pine/40 px-6 py-3.5 text-center font-medium text-pine transition-colors hover:bg-pine/5"
      >
        Begin the Conversation
      </a>
      <a
        href={withBase("/donate")}
        class="block rounded-full bg-pine px-6 py-3.5 text-center font-semibold text-linen transition-colors hover:bg-forest"
      >
        Donate
      </a>
    </div>
  </aside>

<script>
  const header = document.getElementById("site-header");
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const backdrop = document.getElementById("menu-backdrop");
  const closeBtn = document.getElementById("menu-close");
  const menuLinks = menu?.querySelectorAll("a");

  let menuOpen = false;
  const syncHeader = () => {
    const solid = window.scrollY > 12 || menuOpen;
    header?.classList.toggle("is-scrolled", solid);
  };

  window.addEventListener("scroll", syncHeader, { passive: true });
  syncHeader();

  const setMenu = (open: boolean) => {
    menuOpen = open;
    menu?.classList.toggle("translate-x-full", !open);
    menu?.setAttribute("aria-hidden", String(!open));
    backdrop?.classList.toggle("opacity-0", !open);
    backdrop?.classList.toggle("pointer-events-none", !open);
    toggle?.setAttribute("aria-expanded", String(open));
    document.body.style.overflow = open ? "hidden" : "";
    syncHeader();
  };

  toggle?.addEventListener("click", () => setMenu(!menuOpen));
  closeBtn?.addEventListener("click", () => setMenu(false));
  backdrop?.addEventListener("click", () => setMenu(false));
  menuLinks?.forEach((a) => a.addEventListener("click", () => setMenu(false)));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menuOpen) setMenu(false);
  });
</script>
